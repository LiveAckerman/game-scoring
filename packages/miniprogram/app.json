{
  "pages": [
    "pages/home/home",
    "pages/records/records",
    "pages/profile/profile"
  ],
  "subpackages": [
    {
      "root": "subpkg",
      "pages": [
        "login/login",
        "multi-invite/multi-invite",
        "profile-edit/profile-edit"
      ]
    }
  ],
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#D32F2F",
    "navigationBarTitleText": "欢乐记分馆",
    "navigationBarTextStyle": "white"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#D32F2F",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/home/home",
        "text": "首页",
        "iconPath": "assets/icons/home.png",
        "selectedIconPath": "assets/icons/home-active.png"
      },
      {
        "pagePath": "pages/records/records",
        "text": "记录",
        "iconPath": "assets/icons/records.png",
        "selectedIconPath": "assets/icons/records-active.png"
      },
      {
        "pagePath": "pages/profile/profile",
        "text": "我的",
        "iconPath": "assets/icons/profile.png",
        "selectedIconPath": "assets/icons/profile-active.png"
      }
    ]
  },
  "style": "v2",
  "usingComponents": {
    "common-top-bar": "/components/common-top-bar/common-top-bar",
    "common-dialog": "/components/common-dialog/common-dialog",
    "invite-card": "/components/invite-card/invite-card"
  },
  "sitemapLocation": "sitemap.json"
}
