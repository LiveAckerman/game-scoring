<view class="home-page">
  <view class="home-header">
    <view class="title-wrap">
      <view class="icon icon-casino"></view>
      <text class="home-title">欢乐记分馆</text>
    </view>
  </view>

  <scroll-view class="home-scroll" scroll-y>
    <view class="hero-card">
      <view class="hero-pattern"></view>
      <view class="hero-main">
        <view>
          <text class="hero-title">开局吧！</text>
          <text class="hero-subtitle">创建牌局，赢个痛快</text>
        </view>
        <view class="hero-badge">
          <view class="icon icon-trophy-white"></view>
        </view>
      </view>
    </view>

    <view class="section-head">
      <view class="line"></view>
      <text class="section-title">开启新局</text>
    </view>

    <view class="mode-card" bindtap="startMultiMode">
      <view>
        <text class="mode-title">多人记分</text>
        <text class="mode-sub">多人对局实时记分</text>
      </view>
      <view class="mode-icon-wrap red">
        <view class="icon icon-groups"></view>
      </view>
    </view>

    <view class="mode-card" bindtap="startSingleMode">
      <view>
        <text class="mode-title">单人记分</text>
        <text class="mode-sub">单人视角专注记分</text>
      </view>
      <view class="mode-icon-wrap orange">
        <view class="icon icon-person"></view>
      </view>
    </view>

    <view class="mode-card" bindtap="startPoolMode">
      <view>
        <text class="mode-title">分数池模式</text>
        <text class="mode-sub">筹码管理与公共池</text>
      </view>
      <view class="mode-icon-wrap yellow">
        <view class="icon icon-savings"></view>
      </view>
    </view>

    <view class="section-head recent-head">
      <view class="line"></view>
      <text class="section-title">最近一桌</text>
      <text class="view-all" bindtap="viewAllRecords">查看全部</text>
    </view>

    <view class="table-card">
      <view class="table-top">
        <text class="table-name">多人记分桌</text>
        <text class="status active">进行中</text>
      </view>
      <view class="players-row">
        <view class="player-col">
          <view class="avatar-wrap">
            <image class="avatar" src="../../assets/stitch/avatars/avatar-b.png" mode="aspectFill" />
            <text class="host-tag">桌主</text>
          </view>
          <text class="score neg">-20</text>
        </view>
        <view class="split"></view>
        <view class="player-col">
          <image class="avatar small" src="../../assets/stitch/avatars/avatar-c.png" mode="aspectFill" />
          <text class="score pos">20</text>
        </view>
      </view>
      <view class="table-foot">
        <text class="time">3月2日, 11:28 • 0 分钟</text>
        <view class="actions">
          <view class="action-btn"><view class="icon icon-chart"></view></view>
          <view class="action-btn active"><view class="icon icon-power"></view></view>
        </view>
      </view>
    </view>

    <view class="table-card soft">
      <view class="table-top">
        <text class="table-name">单人记分桌</text>
        <text class="status active">进行中</text>
      </view>
      <view class="players-row">
        <view class="player-col">
          <view class="avatar-wrap">
            <image class="avatar" src="../../assets/stitch/avatars/avatar-d.png" mode="aspectFill" />
            <text class="host-tag">桌主</text>
          </view>
          <text class="score neg">-123</text>
        </view>
      </view>
      <view class="table-foot">
        <text class="time">3月2日, 11:28 • 1 分钟</text>
        <view class="actions">
          <view class="action-btn"><view class="icon icon-chart"></view></view>
          <view class="action-btn"><view class="icon icon-delete"></view></view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
