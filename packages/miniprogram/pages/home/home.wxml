<page-meta page-style="{{pageFontStyle}}" />
<view class="home-page">
  <common-top-bar title="欢乐记分馆" showBack="{{false}}" />

  <scroll-view class="home-scroll" scroll-y>
    <view class="hero-card">
      <view class="hero-pattern"></view>
      <view class="hero-main">
        <view>
          <text class="hero-title">开局吧！</text>
          <text class="hero-subtitle">创建牌局，赢个痛快</text>
        </view>
        <view class="hero-badge">
          <view class="icon icon-trophy-white"></view>
        </view>
      </view>
    </view>

    <view class="section-head">
      <view class="line"></view>
      <text class="section-title">开启新局</text>
    </view>

    <view class="mode-card" bindtap="startMultiMode">
      <view>
        <text class="mode-title">多人记分</text>
        <text class="mode-sub">多人对局实时记分</text>
      </view>
      <view class="mode-icon-wrap red">
        <view class="icon icon-groups"></view>
      </view>
    </view>

    <view class="mode-card" bindtap="startSingleMode">
      <view>
        <text class="mode-title">单人记分</text>
        <text class="mode-sub">单人视角专注记分</text>
      </view>
      <view class="mode-icon-wrap orange">
        <view class="icon icon-person"></view>
      </view>
    </view>

    <view class="mode-card" bindtap="startPoolMode">
      <view>
        <text class="mode-title">分数池模式</text>
        <text class="mode-sub">筹码管理与公共池</text>
      </view>
      <view class="mode-icon-wrap yellow">
        <view class="icon icon-savings"></view>
      </view>
    </view>

    <view class="join-entry-card" bindtap="openJoinDialog">
      <view class="join-entry-left">
        <view class="join-entry-icon">
          <view class="icon icon-keypad"></view>
        </view>
        <view class="join-entry-copy">
          <text class="join-entry-title">加入房间</text>
          <text class="join-entry-sub">输入6位房间号，快速加入正在进行的牌局</text>
        </view>
      </view>
      <text class="join-entry-action">去加入</text>
    </view>

    <view class="section-head recent-head">
      <view class="line"></view>
      <text class="section-title">最近5局</text>
      <text class="view-all" bindtap="viewAllRecords">查看全部</text>
    </view>

    <view wx:if="{{historyLoading}}" class="empty-history">加载中...</view>
    <view wx:elif="{{recentRooms.length === 0}}" class="empty-history">暂无历史对局，开一局试试吧</view>

    <table-card
      wx:for="{{recentRooms}}"
      wx:for-item="room"
      wx:key="roomId"
      roomCode="{{room.roomCode}}"
      status="{{room.status}}"
      statusText="{{room.statusText}}"
      roomType="{{room.roomType || 'MULTI'}}"
      members="{{room.previewMembers}}"
      timeText="{{room.timeText}}"
      durationText="{{room.durationText}}"
      myScoreText="{{room.myScoreText}}"
      tags="{{room.tags}}"
      faded="{{room.status === 'ENDED'}}"
      bind:cardtap="openRecentRoom"
      data-room-code="{{room.roomCode}}"
      data-room-type="{{room.roomType}}"
      data-status="{{room.status}}"
    />
  </scroll-view>

  <common-dialog
    visible="{{joinDialogVisible}}"
    title="加入房间"
    showClose="{{true}}"
    maskClosable="{{true}}"
    bind:close="closeJoinDialog"
  >
    <view class="join-dialog-tip">请输入6位房间号，快速加入好友牌局</view>
    <view class="join-code-wrap" bindtap="focusJoinCodeInput">
      <view class="join-code-grid">
        <view
          wx:for="{{joinCodeDigits}}"
          wx:key="index"
          class="join-code-cell {{joinRoomCode.length === index ? 'active' : ''}}"
        >
          <text class="join-code-char">{{item}}</text>
        </view>
      </view>
      <input
        class="join-hidden-input"
        type="number"
        maxlength="6"
        value="{{joinRoomCode}}"
        focus="{{joinCodeFocus}}"
        bindinput="onJoinCodeInput"
        bindblur="onJoinCodeBlur"
      />
    </view>
    <view slot="footer" class="join-dialog-footer">
      <button class="join-dialog-btn ghost" bindtap="closeJoinDialog">取消</button>
      <button
        class="join-dialog-btn"
        bindtap="confirmJoinRoom"
        loading="{{joiningRoom}}"
        disabled="{{joiningRoom}}"
      >加入房间</button>
    </view>
  </common-dialog>

  <common-dialog
    visible="{{ongoingDialogVisible}}"
    title="{{ongoingReachedLimit ? '进行中的对局已达上限' : '你有进行中的对局'}}"
    showFooter="{{false}}"
    bind:close="closeOngoingDialog"
  >
    <view class="ongoing-tip">{{ongoingReachedLimit ? '同类型房间最多同时进行 3 个，请先结束部分对局。' : '检测到你还有正在进行中的对局，可直接进入，或新开一局。'}}</view>
    <view class="ongoing-list">
      <table-card
        wx:for="{{ongoingRooms}}"
        wx:for-item="room"
        wx:key="roomId"
        roomCode="{{room.roomCode}}"
        status="{{room.status}}"
        statusText="{{room.statusText}}"
        roomType="{{room.roomType || 'MULTI'}}"
        members="{{room.previewMembers}}"
        timeText="{{room.timeText}}"
        durationText="{{room.durationText}}"
        myScoreText="{{room.myScoreText}}"
        tags="{{room.tags}}"
        bind:cardtap="enterOngoingRoom"
        data-room-code="{{room.roomCode}}"
        data-room-type="{{room.roomType}}"
      />
    </view>
    <view slot="footer" class="ongoing-dialog-footer">
      <button class="ongoing-dialog-btn ghost" bindtap="closeOngoingDialog">{{ongoingReachedLimit ? '知道了' : '稍后再说'}}</button>
      <button wx:if="{{!ongoingReachedLimit}}" class="ongoing-dialog-btn" bindtap="handleCreateNewRoomFromDialog">开启新对局</button>
    </view>
  </common-dialog>

  <common-dialog
    visible="{{inputDialogVisible}}"
    title="{{inputDialogTitle}}"
    showClose="{{true}}"
    maskClosable="{{true}}"
    bind:close="cancelInputDialog"
  >
    <view class="input-dialog-tip">{{inputDialogTip}}</view>
    <input
      class="input-dialog-input"
      type="text"
      maxlength="64"
      value="{{inputDialogValue}}"
      placeholder="{{inputDialogPlaceholder}}"
      focus="{{inputDialogVisible}}"
      bindinput="onInputDialogInput"
    />
    <view slot="footer" class="join-dialog-footer">
      <button class="join-dialog-btn ghost" bindtap="cancelInputDialog">取消</button>
      <button class="join-dialog-btn" bindtap="confirmInputDialog">{{inputDialogConfirmText}}</button>
    </view>
  </common-dialog>
</view>
