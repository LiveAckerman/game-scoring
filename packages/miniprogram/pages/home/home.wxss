.home-page {
  min-height: 100vh;
  background: #fff5f5;
}

.home-header {
  position: sticky;
  top: 0;
  z-index: 10;
  background: rgba(255, 245, 245, 0.95);
  backdrop-filter: blur(12rpx);
  padding: 26rpx 32rpx 20rpx;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.title-icon {
  font-size: 44rpx;
}

.title {
  font-size: 42rpx;
  line-height: 1;
  color: #d93025;
  font-weight: 700;
}

.home-scroll {
  height: calc(100vh - 92rpx);
  padding: 24rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.hero-card {
  position: relative;
  border-radius: 32rpx;
  padding: 34rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  background: linear-gradient(135deg, #ff6f00 0%, #d32f2f 100%);
  box-shadow: 0 10rpx 28rpx rgba(211, 47, 47, 0.2);
  overflow: hidden;
}

.hero-dot {
  position: absolute;
  right: -50rpx;
  bottom: -40rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.hero-left {
  z-index: 1;
}

.hero-title {
  display: block;
  color: #fff;
  font-size: 42rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.hero-subtitle {
  color: #ffe9c8;
  font-size: 24rpx;
}

.hero-right {
  z-index: 1;
  width: 78rpx;
  height: 78rpx;
  border-radius: 39rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  font-size: 44rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 18rpx 0;
}

.recent-title-wrap {
  margin-top: 30rpx;
}

.section-line {
  width: 8rpx;
  height: 34rpx;
  border-radius: 8rpx;
  background: #d93025;
}

.section-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #2a2a2a;
}

.view-all {
  font-size: 22rpx;
  color: #8f8f8f;
}

.mode-card {
  background: #fff;
  border-radius: 26rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  border: 2rpx solid #f6e8e8;
}

.mode-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 6rpx;
}

.mode-desc {
  font-size: 22rpx;
  color: #989898;
}

.mode-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
}

.mode-icon-red {
  background: #fff1f0;
}

.mode-icon-orange {
  background: #fff6eb;
}

.mode-icon-gold {
  background: #fff9e7;
}

.recent-card {
  background: #fff;
  border-radius: 26rpx;
  padding: 24rpx;
  border: 2rpx solid #f2f2f2;
  margin-bottom: 18rpx;
}

.mute-card {
  opacity: 0.92;
}

.recent-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.recent-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #5a5a5a;
}

.status-tag {
  font-size: 20rpx;
  color: #2b8a3e;
  background: #eaf8ed;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}

.recent-players {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.player-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.avatar-wrap {
  position: relative;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  border: 3rpx solid #d93025;
}

.avatar.small {
  width: 74rpx;
  height: 74rpx;
  border-color: transparent;
}

.host-tag {
  position: absolute;
  right: -10rpx;
  top: -8rpx;
  font-size: 16rpx;
  color: #fff;
  background: #d93025;
  border-radius: 16rpx;
  padding: 2rpx 8rpx;
}

.score {
  font-size: 36rpx;
  font-weight: 700;
}

.score-neg {
  color: #333;
}

.score-pos {
  color: #d93025;
}

.split-line {
  width: 2rpx;
  height: 56rpx;
  background: #ededed;
}

.recent-foot {
  padding-top: 16rpx;
  border-top: 2rpx solid #f3f3f3;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.recent-time {
  font-size: 20rpx;
  color: #9f9f9f;
}

.recent-actions {
  display: flex;
  gap: 12rpx;
}

.action {
  width: 54rpx;
  height: 54rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f7f7f7;
}

.action.active {
  background: #fde9e7;
}
