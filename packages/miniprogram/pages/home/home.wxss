.home-page { min-height: 100vh; background: #fff5f5; }
.home-header { position: sticky; top: 0; z-index: 20; background: rgba(255,245,245,.94); padding: 24rpx 30rpx; }
.title-wrap { display: flex; align-items: center; gap: 10rpx; }
.home-title { font-size: 42rpx; font-weight: 700; color: #d93025; }
.home-scroll { height: calc(100vh - 96rpx); box-sizing: border-box; padding: 20rpx 24rpx 34rpx; }
.hero-card { position: relative; overflow: hidden; border-radius: 30rpx; padding: 32rpx; background: linear-gradient(135deg,#ff6f00,#d32f2f); box-shadow: 0 10rpx 26rpx rgba(217,48,37,.24); }
.hero-pattern { position: absolute; inset: 0; opacity: .1; background-image: radial-gradient(#ffd54f 10%, transparent 12%), radial-gradient(#ffd54f 10%, transparent 12%); background-size: 24rpx 24rpx; background-position: 0 0, 12rpx 12rpx; }
.hero-main { position: relative; z-index: 2; display: flex; justify-content: space-between; align-items: center; }
.hero-title { display: block; color: #fff; font-size: 40rpx; font-weight: 700; margin-bottom: 8rpx; }
.hero-subtitle { color: #ffe8c7; font-size: 24rpx; }
.hero-badge { width: 74rpx; height: 74rpx; border-radius: 37rpx; background: rgba(255,255,255,.22); display: flex; align-items: center; justify-content: center; }
.section-head { display: flex; align-items: center; gap: 12rpx; margin: 26rpx 0 14rpx; }
.recent-head { margin-top: 32rpx; }
.line { width: 8rpx; height: 34rpx; border-radius: 8rpx; background: #d93025; }
.section-title { flex: 1; font-size: 32rpx; font-weight: 700; color: #2f2f2f; }
.view-all { font-size: 22rpx; color: #8e8e8e; }
.mode-card { background: #fff; border-radius: 24rpx; padding: 26rpx; display: flex; align-items: center; justify-content: space-between; border: 2rpx solid #f3ebeb; margin-bottom: 16rpx; }
.mode-title { display: block; font-size: 32rpx; font-weight: 700; color: #333; margin-bottom: 6rpx; }
.mode-sub { font-size: 22rpx; color: #989898; }
.mode-icon-wrap { width: 76rpx; height: 76rpx; border-radius: 38rpx; display: flex; align-items: center; justify-content: center; }
.mode-icon-wrap.red { background: #fff1f1; }
.mode-icon-wrap.orange { background: #fff5eb; }
.mode-icon-wrap.yellow { background: #fff8e2; }
.table-card { background: #fff; border-radius: 24rpx; padding: 24rpx; border: 2rpx solid #f0f0f0; margin-bottom: 16rpx; }
.table-card.soft { opacity: .92; }
.table-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx; }
.table-name { font-size: 26rpx; font-weight: 700; color: #5b5b5b; }
.status { font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 10rpx; }
.status.active { background: #e9f8ed; color: #2f8b45; }
.players-row { display: flex; align-items: center; gap: 22rpx; margin-bottom: 14rpx; }
.player-col { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.avatar-wrap { position: relative; }
.avatar { width: 88rpx; height: 88rpx; border-radius: 44rpx; border: 3rpx solid #d93025; }
.avatar.small { width: 74rpx; height: 74rpx; border-color: transparent; }
.host-tag { position: absolute; top: -8rpx; right: -10rpx; font-size: 16rpx; color: #fff; background: #d93025; border-radius: 16rpx; padding: 2rpx 8rpx; }
.score { font-size: 36rpx; font-weight: 700; }
.score.neg { color: #333; }
.score.pos { color: #d93025; }
.split { width: 2rpx; height: 56rpx; background: #ececec; }
.table-foot { border-top: 2rpx solid #f3f3f3; padding-top: 14rpx; display: flex; justify-content: space-between; align-items: center; }
.time { font-size: 20rpx; color: #a0a0a0; }
.actions { display: flex; gap: 12rpx; }
.action-btn { width: 52rpx; height: 52rpx; border-radius: 14rpx; background: #f6f6f6; display: flex; align-items: center; justify-content: center; }
.action-btn.active { background: #fde9e7; }

.icon { background-size: contain; background-repeat: no-repeat; background-position: center; }
