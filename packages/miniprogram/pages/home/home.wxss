.home-page { min-height: 100vh; background: #fff5f5; display: flex; flex-direction: column; }
.home-scroll { flex: 1; box-sizing: border-box; padding: 20rpx 24rpx 34rpx; }
.hero-card { position: relative; overflow: hidden; border-radius: 30rpx; padding: 32rpx; background: linear-gradient(135deg,#ff6f00,#d32f2f); box-shadow: 0 10rpx 26rpx rgba(217,48,37,.24); }
.hero-pattern { position: absolute; inset: 0; opacity: .1; background-image: radial-gradient(#ffd54f 10%, transparent 12%), radial-gradient(#ffd54f 10%, transparent 12%); background-size: 24rpx 24rpx; background-position: 0 0, 12rpx 12rpx; }
.hero-main { position: relative; z-index: 2; display: flex; justify-content: space-between; align-items: center; }
.hero-title { display: block; color: #fff; font-size: var(--fs-xl, 38rpx); font-weight: 700; margin-bottom: 8rpx; }
.hero-subtitle { color: #ffe8c7; font-size: var(--fs-sm, 24rpx); }
.hero-badge { width: 74rpx; height: 74rpx; border-radius: 37rpx; background: rgba(255,255,255,.22); display: flex; align-items: center; justify-content: center; }
.section-head { display: flex; align-items: center; gap: 12rpx; margin: 26rpx 0 14rpx; }
.recent-head { margin-top: 32rpx; }
.line { width: 8rpx; height: 34rpx; border-radius: 8rpx; background: #d93025; }
.section-title { flex: 1; font-size: var(--fs-lg, 34rpx); font-weight: 700; color: #2f2f2f; }
.view-all { font-size: var(--fs-sm, 24rpx); color: #8e8e8e; }
.mode-card { background: #fff; border-radius: 24rpx; padding: 26rpx; display: flex; align-items: center; justify-content: space-between; border: 2rpx solid #f3ebeb; margin-bottom: 16rpx; }
.mode-title { display: block; font-size: var(--fs-lg, 34rpx); font-weight: 700; color: #333; margin-bottom: 6rpx; }
.mode-sub { font-size: var(--fs-sm, 24rpx); color: #989898; }
.mode-icon-wrap { width: 76rpx; height: 76rpx; border-radius: 38rpx; display: flex; align-items: center; justify-content: center; }
.mode-icon-wrap.red { background: #fff1f1; }
.mode-icon-wrap.orange { background: #fff5eb; }
.mode-icon-wrap.yellow { background: #fff8e2; }
.join-entry-card {
  border-radius: 24rpx;
  border: 2rpx dashed rgba(217, 48, 37, 0.3);
  background: linear-gradient(135deg, #fffef9, #fff7ec);
  padding: 22rpx 24rpx;
  margin-top: 2rpx;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.join-entry-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}
.join-entry-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #fff1e0;
  border: 2rpx solid rgba(244, 162, 97, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.join-entry-copy {
  min-width: 0;
}
.join-entry-title {
  display: block;
  color: #3a3a3a;
  font-size: var(--fs-base, 28rpx);
  line-height: 1.2;
  font-weight: 700;
}
.join-entry-sub {
  display: block;
  margin-top: 4rpx;
  color: #959595;
  font-size: var(--fs-sm, 24rpx);
  line-height: 1.3;
}
.join-entry-action {
  padding: 0 18rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 28rpx;
  font-size: var(--fs-sm, 24rpx);
  font-weight: 700;
  color: #fff;
  background: #d93025;
  flex-shrink: 0;
}
.empty-history { background: #fff; border: 2rpx dashed #f1d9d9; border-radius: 20rpx; color: #a68585; font-size: var(--fs-sm, 24rpx); text-align: center; padding: 28rpx 12rpx; margin-bottom: 16rpx; }
.join-dialog-tip {
  color: #8d8d8d;
  font-size: var(--fs-sm, 24rpx);
  line-height: 1.5;
  margin-bottom: 18rpx;
}
.join-code-wrap {
  position: relative;
}
.join-code-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 10rpx;
}
.join-code-cell {
  height: 98rpx;
  border-radius: 18rpx;
  background: #fff4ec;
  border: 2rpx solid rgba(230, 57, 70, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}
.join-code-cell.active {
  border-color: #e63946;
  box-shadow: inset 0 0 0 2rpx rgba(230, 57, 70, 0.12);
}
.join-code-char {
  color: #d93025;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 700;
}
.join-hidden-input {
  position: absolute;
  width: 1px;
  height: 1px;
  opacity: 0;
  pointer-events: none;
  left: -9999rpx;
}
.join-dialog-footer {
  display: flex;
  gap: 12rpx;
  padding-top: 18rpx;
}
.join-dialog-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 18rpx;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  background: #e63946;
  color: #fff;
  font-size: var(--fs-base, 28rpx);
  font-weight: 700;
  line-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}
.join-dialog-btn.ghost {
  background: #f6f2eb;
  color: #666;
}
.join-dialog-btn::after {
  border: none;
}
.input-dialog-tip {
  color: #8d8d8d;
  font-size: var(--fs-sm, 24rpx);
  line-height: 1.45;
  margin-bottom: 14rpx;
}
.input-dialog-input {
  width: 100%;
  height: 92rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(230, 57, 70, 0.2);
  background: #fff8f0;
  font-size: var(--fs-md, 30rpx);
  color: #333;
  box-sizing: border-box;
  padding: 0 22rpx;
}
.ongoing-tip { color: #8d8d8d; font-size: var(--fs-sm, 24rpx); margin-bottom: 16rpx; }
.ongoing-list { display: flex; flex-direction: column; gap: 12rpx; }
.ongoing-item { border: 2rpx solid #f2e6e6; border-radius: 18rpx; padding: 18rpx; display: flex; justify-content: space-between; align-items: center; background: #fffdf9; }
.ongoing-main { display: flex; flex-direction: column; gap: 6rpx; }
.ongoing-room { font-size: var(--fs-md, 30rpx); color: #333; font-weight: 700; }
.ongoing-meta { font-size: var(--fs-sm, 24rpx); color: #8a8a8a; }
.ongoing-time { font-size: var(--fs-sm, 24rpx); color: #b2b2b2; }

