.records-page { min-height: 100vh; background: linear-gradient(180deg, var(--c-surface-app), var(--c-surface-warm)); display: flex; flex-direction: column; }
.header-bar { position: sticky; top: 0; z-index: 20; display: flex; align-items: center; justify-content: space-between; padding: 22rpx 24rpx; background: var(--c-surface-app); border-bottom: 2rpx solid var(--c-border-soft); }
.tabs { display: flex; padding: 8rpx; border-radius: 26rpx; background: var(--c-surface-card); border: 2rpx solid var(--c-border-soft); }
.tab { min-width: 140rpx; padding: 16rpx 30rpx; font-size: var(--fs-base, 28rpx); color: var(--c-text-secondary); border-radius: 22rpx; text-align: center; box-sizing: border-box; }
.tab.active { background: linear-gradient(135deg, var(--c-brand-red), var(--c-brand-gold)); color: var(--c-text-on-brand); font-weight: 700; box-shadow: 0 8rpx 16rpx rgba(183,55,39,.14); }
.filter-btn { min-width: 160rpx; height: 64rpx; line-height: 64rpx; padding: 0 22rpx; border-radius: 32rpx; background: var(--c-brand-gold-soft); color: var(--c-brand-gold-strong); font-size: var(--fs-sm, 24rpx); font-weight: 700; text-align: center; box-sizing: border-box; }

.content { flex: 1; padding: 16rpx 24rpx 26rpx; box-sizing: border-box; }
.summary-card { background: linear-gradient(180deg, var(--c-surface-card), var(--c-surface-red)); border-radius: 28rpx; padding: 24rpx; border: 2rpx solid var(--c-border-soft); box-shadow: 0 12rpx 24rpx rgba(183,55,39,.08); margin-bottom: 16rpx; }
.summary-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx; }
.tip { font-size: var(--fs-sm, 24rpx); color: var(--c-text-secondary); }
.count { color: var(--c-brand-red); font-weight: 700; font-size: var(--fs-base, 28rpx); }
.summary-grid { display: grid; grid-template-columns: repeat(3, 1fr); margin-bottom: 14rpx; }
.stat-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.split-v { border-left: 2rpx solid var(--c-border-soft); border-right: 2rpx solid var(--c-border-soft); }
.stat-label { font-size: var(--fs-sm, 24rpx); color: var(--c-text-secondary); }
.stat-value { font-size: var(--fs-lg, 34rpx); color: var(--c-text-primary); font-weight: 700; }
.stat-value.red { color: var(--c-brand-red); }
.stat-value.gray { color: var(--c-text-secondary); }
.summary-foot { border-top: 2rpx dashed var(--c-border-soft); padding-top: 12rpx; display: flex; justify-content: space-around; color: var(--c-text-secondary); font-size: var(--fs-sm, 24rpx); }

.page-tip { background: var(--c-surface-card); border: 2rpx dashed var(--c-border-soft); border-radius: 20rpx; color: var(--c-text-secondary); text-align: center; font-size: var(--fs-sm, 24rpx); padding: 24rpx 12rpx; margin-bottom: 14rpx; }

.sheet-mask { position: fixed; inset: 0; background: rgba(0, 0, 0, 0.38); z-index: 999; display: flex; align-items: flex-end; }
.sheet-panel { width: 100%; background: linear-gradient(180deg, var(--c-surface-card), var(--c-surface-card-alt)); border-radius: 32rpx 32rpx 0 0; padding: 28rpx 24rpx calc(12rpx + env(safe-area-inset-bottom)); box-sizing: border-box; }
.sheet-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.sheet-title { font-size: var(--fs-lg, 34rpx); color: var(--c-text-primary); font-weight: 700; }
.sheet-close { font-size: var(--fs-sm, 24rpx); color: var(--c-text-secondary); }
.sheet-room-code { display: block; margin-bottom: 16rpx; font-size: var(--fs-sm, 24rpx); color: var(--c-text-secondary); }
.sheet-tag-list { display: flex; flex-wrap: wrap; gap: 14rpx; margin-bottom: 22rpx; }
.sheet-tag { min-height: 56rpx; padding: 0 18rpx; border-radius: 28rpx; border: 2rpx solid var(--c-brand-red); display: inline-flex; align-items: center; box-sizing: border-box; font-size: var(--fs-sm, 24rpx); font-weight: 700; }
.sheet-empty { padding: 30rpx 12rpx; text-align: center; }
.sheet-empty-title { display: block; font-size: var(--fs-base, 28rpx); color: var(--c-text-primary); font-weight: 700; margin-bottom: 10rpx; }
.sheet-empty-desc { display: block; font-size: var(--fs-sm, 24rpx); color: var(--c-text-secondary); line-height: 1.7; margin-bottom: 18rpx; }
.sheet-link-btn { display: inline-block; min-width: 180rpx; height: 60rpx; line-height: 60rpx; padding: 0 20rpx; border-radius: 30rpx; background: var(--c-brand-gold-soft); color: var(--c-brand-gold-strong); font-size: var(--fs-sm, 24rpx); font-weight: 700; }
.sheet-actions { display: flex; gap: 14rpx; margin-top: 8rpx; }
.sheet-btn { flex: 1; height: 84rpx; line-height: 84rpx; border-radius: 22rpx; background: linear-gradient(135deg, var(--c-brand-red), var(--c-brand-gold)); color: var(--c-text-on-brand); font-size: var(--fs-base, 28rpx); font-weight: 700; text-align: center; }
.sheet-btn.ghost { background: var(--c-surface-warm); color: var(--c-text-secondary); }
