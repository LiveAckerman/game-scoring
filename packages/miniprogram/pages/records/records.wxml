<view class="records-page">
  <view class="header-bar">
    <view class="tabs">
      <view class="tab {{activeTab === 'all' ? 'active' : ''}}" data-id="all" bindtap="switchTab">全部</view>
      <view class="tab {{activeTab === 'ongoing' ? 'active' : ''}}" data-id="ongoing" bindtap="switchTab">进行中</view>
      <view class="tab {{activeTab === 'finished' ? 'active' : ''}}" data-id="finished" bindtap="switchTab">已结束</view>
    </view>
    <view class="tools">
      <view class="tool-btn"><view class="icon icon-filter"></view></view>
      <view class="tool-btn"><view class="icon icon-delete"></view></view>
    </view>
  </view>

  <scroll-view class="content" scroll-y>
    <view class="summary-card">
      <view class="summary-top">
        <text class="tip">当前筛选共计 <text class="count">4</text> 条记录</text>
        <view class="rank-btn">
          <text>查看战绩榜</text>
          <view class="icon icon-chart-green"></view>
        </view>
      </view>
      <view class="summary-grid">
        <view class="stat-item">
          <text class="stat-label">赢局</text>
          <text class="stat-value">0场</text>
        </view>
        <view class="stat-item split-v">
          <text class="stat-label">总赢</text>
          <text class="stat-value red">0分</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">总输</text>
          <text class="stat-value gray">-143分</text>
        </view>
      </view>
      <view class="summary-foot">
        <text>输局 2</text>
        <text>平局 2</text>
        <text>总和 -143</text>
      </view>
    </view>

    <view class="record-card">
      <view class="record-head">
        <view class="title-row">
          <text class="record-title">多人计分桌</text>
          <text class="badge">进行中</text>
        </view>
        <view class="head-actions">
          <view class="round-btn"><view class="icon icon-chart"></view></view>
          <view class="round-btn"><view class="icon icon-tag"></view></view>
          <view class="round-btn"><view class="icon icon-power"></view></view>
          <view class="round-btn"><view class="icon icon-delete"></view></view>
        </view>
      </view>
      <view class="players">
        <view class="p-item">
          <view class="avatar-box">
            <image class="avatar" src="../../assets/stitch/avatars/avatar-e.png" mode="aspectFill" />
            <text class="host">桌主</text>
          </view>
          <text class="name">君の名...</text>
          <text class="score">-20</text>
        </view>
        <view class="p-item">
          <image class="avatar muted" src="../../assets/stitch/avatars/avatar-f.png" mode="aspectFill" />
          <text class="name">Y.</text>
          <text class="score red">20</text>
        </view>
      </view>
      <view class="card-foot">
        <text>26-03-02 11:28 开始</text>
        <text>已进行0分钟</text>
      </view>
    </view>

    <view class="record-card soft">
      <view class="record-head">
        <view class="title-row">
          <text class="record-title">单人计分桌</text>
          <text class="badge">进行中</text>
        </view>
        <view class="head-actions">
          <view class="round-btn"><view class="icon icon-chart"></view></view>
          <view class="round-btn"><view class="icon icon-delete"></view></view>
        </view>
      </view>
      <view class="players">
        <view class="p-item">
          <view class="avatar-box">
            <image class="avatar" src="../../assets/stitch/avatars/avatar-g.png" mode="aspectFill" />
            <text class="host">桌主</text>
          </view>
          <text class="name">君の名...</text>
          <text class="score">-123</text>
        </view>
      </view>
      <view class="card-foot">
        <text>26-03-02 11:28 开始</text>
        <text>已进行1分钟</text>
      </view>
    </view>
  </scroll-view>
</view>
