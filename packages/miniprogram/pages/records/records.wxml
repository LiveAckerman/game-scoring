<view class="records-page">
  <common-top-bar title="计分记录" showBack="{{false}}" />

  <view class="header-bar">
    <view class="tabs">
      <view class="tab {{activeTab === 'all' ? 'active' : ''}}" data-id="all" bindtap="switchTab">全部</view>
      <view class="tab {{activeTab === 'ongoing' ? 'active' : ''}}" data-id="ongoing" bindtap="switchTab">进行中</view>
      <view class="tab {{activeTab === 'finished' ? 'active' : ''}}" data-id="finished" bindtap="switchTab">已结束</view>
    </view>
  </view>

  <scroll-view class="content" scroll-y>
    <view class="summary-card">
      <view class="summary-top">
        <text class="tip">当前筛选共计 <text class="count">{{totalRecords}}</text> 条记录</text>
      </view>
      <view class="summary-grid">
        <view class="stat-item">
          <text class="stat-label">赢局</text>
          <text class="stat-value">{{summary.winRounds}}场</text>
        </view>
        <view class="stat-item split-v">
          <text class="stat-label">总赢</text>
          <text class="stat-value red">{{summary.totalWinPoints}}分</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">总输</text>
          <text class="stat-value gray">{{summary.totalLosePoints}}分</text>
        </view>
      </view>
      <view class="summary-foot">
        <text>输局 {{summary.loseRounds}}</text>
        <text>平局 {{summary.drawRounds}}</text>
        <text>总和 {{summary.totalScore}}</text>
      </view>
    </view>

    <view wx:if="{{loading}}" class="page-tip">加载中...</view>
    <view wx:elif="{{records.length === 0}}" class="page-tip">暂无对局记录</view>

    <view
      wx:for="{{records}}"
      wx:key="roomId"
      class="record-card {{item.status === 'ENDED' ? 'soft' : ''}}"
      bindtap="openRoomFromRecord"
      data-room-code="{{item.roomCode}}"
      data-status="{{item.status}}"
    >
      <view class="record-head">
        <view class="title-row">
          <text class="record-title">桌号 {{item.roomCode}}</text>
          <text class="badge {{item.statusClass}}">{{item.statusText}}</text>
        </view>
        <view class="record-meta">
          <text class="meta">我的积分 {{item.myScoreText}}</text>
          <text class="meta">{{item.scoreRecordCount}} 笔记分</text>
        </view>
      </view>

      <view class="players">
        <view wx:for="{{item.members}}" wx:key="id" class="p-item">
          <view class="avatar-box">
            <image wx:if="{{item.avatar}}" class="avatar" src="{{item.avatar}}" mode="aspectFill" />
            <view wx:else class="avatar avatar-text"><text>{{item.avatarInitials || '游客'}}</text></view>
            <text wx:if="{{item.isOwner}}" class="host">桌主</text>
          </view>
          <text class="name">{{item.nickname}}</text>
          <text class="score {{item.score > 0 ? 'red' : (item.score < 0 ? 'dark' : 'zero')}}">{{item.score > 0 ? '+' : ''}}{{item.score}}</text>
        </view>
      </view>

      <view class="card-foot">
        <text>{{item.startText}}</text>
        <text>{{item.durationText}}</text>
      </view>
    </view>
  </scroll-view>
</view>
