<page-meta page-style="{{pageFontStyle}}" />
<view class="records-page">
  <common-top-bar title="计分记录" showBack="{{false}}" />

  <view class="header-bar">
    <view class="tabs">
      <view class="tab {{activeTab === 'all' ? 'active' : ''}}" data-id="all" bindtap="switchTab">全部</view>
      <view class="tab {{activeTab === 'ongoing' ? 'active' : ''}}" data-id="ongoing" bindtap="switchTab">进行中</view>
      <view class="tab {{activeTab === 'finished' ? 'active' : ''}}" data-id="finished" bindtap="switchTab">已结束</view>
    </view>
    <view class="filter-btn" bindtap="openTagFilter">
      <text>{{selectedFilterTagIds.length > 0 ? '标签筛选 · ' + selectedFilterTagIds.length : '标签筛选'}}</text>
    </view>
  </view>

  <scroll-view class="content" scroll-y>
    <view class="summary-card">
      <view class="summary-top">
        <text class="tip">当前筛选共计 <text class="count">{{totalRecords}}</text> 条记录</text>
      </view>
      <view class="summary-grid">
        <view class="stat-item">
          <text class="stat-label">赢局</text>
          <text class="stat-value">{{summary.winRounds}}场</text>
        </view>
        <view class="stat-item split-v">
          <text class="stat-label">总赢</text>
          <text class="stat-value red">{{summary.totalWinPoints}}分</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">总输</text>
          <text class="stat-value gray">{{summary.totalLosePoints}}分</text>
        </view>
      </view>
      <view class="summary-foot">
        <text>输局 {{summary.loseRounds}}</text>
        <text>平局 {{summary.drawRounds}}</text>
        <text>总和 {{summary.totalScore}}</text>
      </view>
    </view>

    <view wx:if="{{loading}}" class="page-tip">加载中...</view>
    <view wx:elif="{{records.length === 0}}" class="page-tip">暂无对局记录</view>

    <table-card
      wx:for="{{records}}"
      wx:key="roomId"
      roomCode="{{item.roomCode}}"
      status="{{item.status}}"
      statusText="{{item.statusText}}"
      roomType="{{item.roomType || 'MULTI'}}"
      members="{{item.members}}"
      timeText="{{item.startText}}"
      durationText="{{item.durationText}}"
      myScoreText="{{item.myScoreText}}"
      scoreCount="{{item.scoreRecordCount}}"
      tags="{{item.tags}}"
      showTagAction="{{true}}"
      showName="{{true}}"
      faded="{{item.status === 'ENDED'}}"
      bind:cardtap="openRoomFromRecord"
      bind:tagtap="openRoomTagDialog"
      data-room-code="{{item.roomCode}}"
      data-room-type="{{item.roomType}}"
      data-status="{{item.status}}"
    />
  </scroll-view>

  <view wx:if="{{tagFilterVisible}}" class="sheet-mask" bindtap="closeTagFilter">
    <view class="sheet-panel" catchtap="noop">
      <view class="sheet-head">
        <text class="sheet-title">标签筛选</text>
        <text class="sheet-close" bindtap="closeTagFilter">关闭</text>
      </view>
      <view wx:if="{{filterTagOptions.length > 0}}" class="sheet-tag-list">
        <view
          wx:for="{{filterTagOptions}}"
          wx:key="id"
          class="sheet-tag {{item.selected ? 'selected' : ''}}"
          style="border-color: {{item.color}}; color: {{item.selected ? '#ffffff' : item.color}}; background-color: {{item.selected ? item.color : '#ffffff'}};"
          catchtap="toggleFilterTag"
          data-tag-id="{{item.id}}"
        >
          <text>{{item.name}}</text>
        </view>
      </view>
      <view wx:else class="sheet-empty">
        <text class="sheet-empty-title">还没有可筛选的标签</text>
        <text class="sheet-empty-desc">先去标签设置页创建标签，再回来给房间打标。</text>
        <view class="sheet-link-btn" bindtap="goToTagSettings">去创建标签</view>
      </view>
      <view class="sheet-actions">
        <view class="sheet-btn ghost" bindtap="clearTagFilter">清空</view>
        <view class="sheet-btn" bindtap="confirmTagFilter">应用</view>
      </view>
    </view>
  </view>

  <view wx:if="{{roomTagVisible}}" class="sheet-mask" bindtap="closeRoomTagDialog">
    <view class="sheet-panel" catchtap="noop">
      <view class="sheet-head">
        <text class="sheet-title">房间标签</text>
        <text class="sheet-close" bindtap="closeRoomTagDialog">关闭</text>
      </view>
      <text class="sheet-room-code">桌号 {{roomTagRoomCode}}</text>
      <view wx:if="{{roomTagOptions.length > 0}}" class="sheet-tag-list">
        <view
          wx:for="{{roomTagOptions}}"
          wx:key="id"
          class="sheet-tag {{item.selected ? 'selected' : ''}}"
          style="border-color: {{item.color}}; color: {{item.selected ? '#ffffff' : item.color}}; background-color: {{item.selected ? item.color : '#ffffff'}};"
          catchtap="toggleRoomTag"
          data-tag-id="{{item.id}}"
        >
          <text>{{item.name}}</text>
        </view>
      </view>
      <view wx:else class="sheet-empty">
        <text class="sheet-empty-title">还没有可用标签</text>
        <text class="sheet-empty-desc">先去标签设置页创建几个常用标签。</text>
        <view class="sheet-link-btn" bindtap="goToTagSettings">去创建标签</view>
      </view>
      <view class="sheet-actions">
        <view class="sheet-btn ghost" bindtap="closeRoomTagDialog">取消</view>
        <view class="sheet-btn" bindtap="confirmRoomTagDialog">保存</view>
      </view>
    </view>
  </view>
</view>
