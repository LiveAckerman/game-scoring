.container {
  min-height: 100vh;
  background-color: #FFF5F5;
  padding: 40rpx;
  box-sizing: border-box;
}

.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.avatar-box {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 100rpx;
  border: 8rpx solid #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
}

.camera-icon {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  background-color: #FFD700;
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #ffffff;
  box-shadow: 0 5rpx 15rpx rgba(0,0,0,0.1);
}

.hint { font-size: 24rpx; color: #999999; }

.form { width: 100%; margin-bottom: 80rpx; }

.form-item { margin-bottom: 40rpx; }

.label { font-size: 32rpx; font-weight: bold; color: #333333; margin-bottom: 20rpx; display: block; }
.label-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.view-all { font-size: 24rpx; color: #D32F2F; }

.input-box {
  background-color: #ffffff;
  height: 100rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.input { flex: 1; font-size: 32rpx; color: #333333; }
.edit-icon { color: #CCCCCC; }

.gender-radio { display: flex; gap: 30rpx; }

.gender-item {
  flex: 1;
  height: 140rpx;
  background-color: #ffffff;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  items-center: center;
  justify-content: center;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.gender-item .icon { font-size: 40rpx; margin-bottom: 8rpx; text-align: center; }
.gender-item text:last-child { font-size: 28rpx; font-weight: bold; color: #333333; text-align: center; }

.gender-item.active { border-color: #3B82F6; background-color: #EFF6FF; }
.gender-item.active:last-child { border-color: #EC4899; background-color: #FDF2F8; }

.title-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }

.title-item {
  background-color: #ffffff;
  padding: 20rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: relative;
  border: 4rpx solid transparent;
}

.title-item.active { border-color: #FFD700; }

.title-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bg-yellow { background-color: #FFFDE7; }
.bg-gray { background-color: #F5F5F5; opacity: 0.5; }

.title-info { display: flex; flex-direction: column; }
.name { font-size: 26rpx; font-weight: bold; color: #D32F2F; }
.name.gray { color: #999999; }
.status { font-size: 18rpx; color: #CCCCCC; }

.check { position: absolute; top: 10rpx; right: 10rpx; }

.save-btn {
  width: 100% !important;
  height: 100rpx;
  background-color: #E63946;
  color: #ffffff;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 30rpx rgba(230, 57, 70, 0.2);
}
