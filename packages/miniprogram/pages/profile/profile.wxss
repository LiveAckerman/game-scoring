.profile-page { min-height: 100vh; background: linear-gradient(180deg, var(--c-surface-app), var(--c-surface-warm)); display: flex; flex-direction: column; }
.profile-scroll { flex: 1; padding: 20rpx 24rpx 30rpx; box-sizing: border-box; }
.login-entry-card { border-radius: 30rpx; padding: 30rpx; background: linear-gradient(135deg, var(--c-surface-card), var(--c-surface-gold)); border: 2rpx solid var(--c-border-soft); box-shadow: 0 10rpx 26rpx rgba(183,55,39,.1); }
.login-entry-main { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.login-entry-left { display: flex; align-items: center; gap: 18rpx; min-width: 0; }
.login-icon-wrap { width: 108rpx; height: 108rpx; border-radius: 54rpx; background: var(--c-brand-gold-soft); border: 2rpx solid var(--c-border-strong); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.login-copy { min-width: 0; display: flex; flex-direction: column; gap: 8rpx; }
.login-title { display: block; color: var(--c-text-primary); font-size: var(--fs-lg, 34rpx); line-height: 1.2; font-weight: 700; }
.login-sub { display: block; color: var(--c-text-secondary); font-size: var(--fs-sm, 24rpx); line-height: 1.4; }
.login-action { height: 62rpx; line-height: 62rpx; border-radius: 31rpx; padding: 0 24rpx; background: linear-gradient(135deg, var(--c-brand-red), var(--c-brand-gold)); color: var(--c-text-on-brand); font-size: var(--fs-sm, 24rpx); font-weight: 700; flex-shrink: 0; }
.user-card { position: relative; overflow: hidden; border-radius: 30rpx; padding: 30rpx; background: linear-gradient(135deg, var(--c-brand-red-strong) 0%, var(--c-brand-red) 52%, var(--c-brand-gold) 100%); box-shadow: 0 12rpx 30rpx rgba(183,55,39,.24); color: var(--c-text-on-brand); }
.bubble { position: absolute; border-radius: 50%; background: rgba(255,255,255,.14); }
.b1 { width: 180rpx; height: 180rpx; right: -50rpx; top: -46rpx; }
.b2 { width: 120rpx; height: 120rpx; left: -36rpx; bottom: -30rpx; }
.card-top { position: relative; z-index: 2; display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.user-left { display: flex; align-items: center; gap: 20rpx; }
.avatar-box { position: relative; }
.avatar { width: 124rpx; height: 124rpx; border-radius: 62rpx; border: 6rpx solid var(--c-brand-gold); }
.vip { position: absolute; right: -10rpx; bottom: -6rpx; background: var(--c-brand-gold); color: var(--c-brand-red); border-radius: 18rpx; font-size: 16rpx; font-weight: 700; padding: 2rpx 10rpx; border: 2rpx solid var(--c-surface-card); }
.name { display: block; font-size: var(--fs-xl, 38rpx); font-weight: 700; margin-bottom: 6rpx; }
.name-row { display: flex; align-items: center; gap: 10rpx; margin-bottom: 6rpx; }
.name-row .name { margin-bottom: 0; }
.edit-icon-btn { width: 44rpx; height: 44rpx; border-radius: 22rpx; background: rgba(255,255,255,.2); border: 2rpx solid rgba(255,255,255,.45); display: flex; align-items: center; justify-content: center; }
.title-chip { display: inline-flex; align-items: center; gap: 6rpx; padding: 4rpx 12rpx; border-radius: 18rpx; background: rgba(0,0,0,.22); font-size: var(--fs-xs, 20rpx); }
.stats { position: relative; z-index: 2; border-top: 2rpx solid rgba(255,255,255,.24); display: flex; padding-top: 18rpx; }
.stat { flex: 1; display: flex; flex-direction: column; align-items: center; }
.split-r { border-right: 2rpx solid rgba(255,255,255,.2); }
.stat .v { font-size: var(--fs-xl, 38rpx); font-weight: 700; }
.stat .k { font-size: var(--fs-xs, 20rpx); opacity: .9; }
.vip-banner { margin-top: 14rpx; border-radius: 20rpx; border: 2rpx solid var(--c-border-strong); background: linear-gradient(90deg, var(--c-brand-gold-soft), var(--c-surface-card)); padding: 20rpx; display: flex; align-items: center; justify-content: space-between; }
.vip-left { display: flex; align-items: center; gap: 16rpx; }
.vip-icon { width: 56rpx; height: 56rpx; border-radius: 28rpx; background: linear-gradient(135deg, var(--c-brand-gold), var(--c-brand-gold-soft)); display: flex; align-items: center; justify-content: center; }
.vip-title { display: block; font-size: var(--fs-base, 28rpx); color: var(--c-brand-gold-strong); font-weight: 700; margin-bottom: 4rpx; }
.vip-desc { font-size: var(--fs-xs, 20rpx); color: var(--c-text-secondary); }
.upgrade { margin: 0; background: var(--c-surface-card); border: 2rpx solid var(--c-border-strong); border-radius: 14rpx; font-size: var(--fs-sm, 24rpx); color: var(--c-brand-red); padding: 8rpx 24rpx; line-height: 1.2; }
.upgrade::after { border: none; }
.service-card { margin-top: 14rpx; background: linear-gradient(180deg, var(--c-surface-card), var(--c-surface-card-alt)); border: 2rpx solid var(--c-border-soft); border-radius: 26rpx; padding: 22rpx; }
.block-title { display: block; font-size: var(--fs-md, 30rpx); font-weight: 700; color: var(--c-text-primary); margin-bottom: 20rpx; }
.service-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28rpx 10rpx; }
.service-item { display: flex; flex-direction: column; align-items: center; gap: 10rpx; font-size: var(--fs-sm, 24rpx); color: var(--c-text-primary); font-weight: 600; }
.service-item text {
  line-height: 1.2;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 2.4em;
  text-align: center;
}
.service-item .icon { width: 40rpx; height: 40rpx; }
.box { width: 96rpx; height: 96rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 2rpx solid rgba(107, 90, 69, 0.08); box-shadow: 0 8rpx 18rpx rgba(107, 90, 69, 0.06); }
.box.red { background: linear-gradient(180deg, #ffe6dd, #f8d0c5); }
.box.orange { background: linear-gradient(180deg, #fff0dc, #f3d4ac); }
.box.yellow { background: linear-gradient(180deg, #fff2d0, #f2dfaa); }
.box.green { background: linear-gradient(180deg, #e6f3ec, #cee4d9); }
.box.blue { background: linear-gradient(180deg, #eef7f3, #d9e8e2); }
.box.purple { background: linear-gradient(180deg, #f7f0e4, #e7d8c1); }
.box.teal { background: linear-gradient(180deg, #e7f4ee, #cfe4d8); }
.box.pink { background: linear-gradient(180deg, #fff2de, #f2dbb7); }
.menu-card { margin-top: 14rpx; background: linear-gradient(180deg, var(--c-surface-card), var(--c-surface-card-alt)); border: 2rpx solid var(--c-border-soft); border-radius: 26rpx; overflow: hidden; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 28rpx; font-size: var(--fs-base, 28rpx); color: var(--c-text-primary); min-height: 108rpx; box-sizing: border-box; }
.share-menu-btn { width: 100% !important; background: transparent; border: none; margin: 0; padding: 0; text-align: left; line-height: 1; font-size: inherit; border-radius: 0; }
.share-menu-btn::after { border: none; }
.share-menu-btn.menu-item { padding: 32rpx 28rpx; }
.menu-item.border { border-bottom: 2rpx solid var(--c-border-soft); }
.left { display: flex; align-items: center; gap: 18rpx; }
.right-info { display: flex; align-items: center; gap: 8rpx; min-width: 0; }
.menu-meta {
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-text-muted);
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.mini { width: 34rpx; height: 34rpx; }
.version { display: block; text-align: center; color: var(--c-text-muted); font-size: var(--fs-xs, 20rpx); margin-top: 24rpx; margin-bottom: 20rpx; }

/* 物料码弹窗 */
.popup-mask { position: fixed; inset: 0; z-index: 999; background: rgba(0,0,0,.5); display: flex; align-items: center; justify-content: center; padding: 48rpx; box-sizing: border-box; }
.popup-body { width: 100%; max-width: 600rpx; background: linear-gradient(180deg, var(--c-surface-card), var(--c-surface-card-alt)); border: 2rpx solid var(--c-border-soft); border-radius: 28rpx; padding: 40rpx 32rpx 32rpx; display: flex; flex-direction: column; align-items: center; }
.popup-title { font-size: var(--fs-lg, 34rpx); font-weight: 700; color: var(--c-text-primary); margin-bottom: 8rpx; }
.popup-desc { font-size: var(--fs-sm, 24rpx); color: var(--c-text-secondary); margin-bottom: 24rpx; }
.qr-preview { width: 400rpx; height: 400rpx; border-radius: 16rpx; margin-bottom: 24rpx; }
.popup-close-btn { width: 100%; height: 80rpx; border-radius: 20rpx; background: var(--c-surface-warm); color: var(--c-text-secondary); font-size: var(--fs-base, 28rpx); font-weight: 700; margin: 0; padding: 0; border: none; display: flex; align-items: center; justify-content: center; }
.popup-close-btn::after { border: none; }

