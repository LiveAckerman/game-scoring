.profile-page { min-height: 100vh; background: #fff5f5; display: flex; flex-direction: column; }
.profile-scroll { flex: 1; padding: 20rpx 24rpx 30rpx; box-sizing: border-box; }
.user-card { position: relative; overflow: hidden; border-radius: 30rpx; padding: 30rpx; background: linear-gradient(135deg,#d93025,#ff6f00); box-shadow: 0 10rpx 30rpx rgba(217,48,37,.22); color: #fff; }
.bubble { position: absolute; border-radius: 50%; background: rgba(255,255,255,.14); }
.b1 { width: 180rpx; height: 180rpx; right: -50rpx; top: -46rpx; }
.b2 { width: 120rpx; height: 120rpx; left: -36rpx; bottom: -30rpx; }
.card-top { position: relative; z-index: 2; display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.user-left { display: flex; align-items: center; gap: 20rpx; }
.avatar-box { position: relative; }
.avatar { width: 124rpx; height: 124rpx; border-radius: 62rpx; border: 6rpx solid #ffd700; }
.vip { position: absolute; right: -10rpx; bottom: -6rpx; background: #ffd700; color: #d93025; border-radius: 18rpx; font-size: 16rpx; font-weight: 700; padding: 2rpx 10rpx; border: 2rpx solid #fff; }
.name { display: block; font-size: 38rpx; font-weight: 700; margin-bottom: 6rpx; }
.name-row { display: flex; align-items: center; gap: 10rpx; margin-bottom: 6rpx; }
.name-row .name { margin-bottom: 0; }
.edit-icon-btn { width: 44rpx; height: 44rpx; border-radius: 22rpx; background: rgba(255,255,255,.2); border: 2rpx solid rgba(255,255,255,.45); display: flex; align-items: center; justify-content: center; }
.title-chip { display: inline-flex; align-items: center; gap: 6rpx; padding: 4rpx 12rpx; border-radius: 18rpx; background: rgba(0,0,0,.22); font-size: 20rpx; }
.stats { position: relative; z-index: 2; border-top: 2rpx solid rgba(255,255,255,.24); display: flex; padding-top: 18rpx; }
.stat { flex: 1; display: flex; flex-direction: column; align-items: center; }
.split-r { border-right: 2rpx solid rgba(255,255,255,.2); }
.stat .v { font-size: 38rpx; font-weight: 700; }
.stat .k { font-size: 20rpx; opacity: .9; }
.vip-banner { margin-top: 14rpx; border-radius: 20rpx; border: 2rpx solid #f3d9a8; background: linear-gradient(90deg,#fff2ce,#fff9ed); padding: 20rpx; display: flex; align-items: center; justify-content: space-between; }
.vip-left { display: flex; align-items: center; gap: 16rpx; }
.vip-icon { width: 56rpx; height: 56rpx; border-radius: 28rpx; background: #ffd700; display: flex; align-items: center; justify-content: center; }
.vip-title { display: block; font-size: 26rpx; color: #6f4a00; font-weight: 700; margin-bottom: 4rpx; }
.vip-desc { font-size: 20rpx; color: #987034; }
.upgrade { margin: 0; background: #fff; border: 2rpx solid #f2d7a4; border-radius: 14rpx; font-size: 22rpx; color: #d93025; padding: 8rpx 24rpx; line-height: 1.2; }
.upgrade::after { border: none; }
.service-card { margin-top: 14rpx; background: #fff; border-radius: 26rpx; padding: 22rpx; }
.block-title { display: block; font-size: 30rpx; font-weight: 700; color: #333; margin-bottom: 20rpx; }
.service-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28rpx 10rpx; }
.service-item { display: flex; flex-direction: column; align-items: center; gap: 10rpx; font-size: 24rpx; color: #666; }
.service-item text { line-height: 1.2; }
.service-item .icon { width: 40rpx; height: 40rpx; }
.box { width: 96rpx; height: 96rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; }
.box.red { background: #fff2f2; }
.box.orange { background: #fff5e9; }
.box.yellow { background: #fff9df; }
.box.green { background: #ecf8ee; }
.box.blue { background: #eaf4ff; }
.box.purple { background: #f3edff; }
.box.teal { background: #e8f8f7; }
.box.pink { background: #fdeef4; }
.menu-card { margin-top: 14rpx; background: #fff; border-radius: 26rpx; overflow: hidden; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 28rpx; font-size: 28rpx; color: #333; min-height: 108rpx; box-sizing: border-box; }
.menu-item.border { border-bottom: 2rpx solid #f4f4f4; }
.left { display: flex; align-items: center; gap: 18rpx; }
.mini { width: 34rpx; height: 34rpx; }
.version { display: block; text-align: center; color: #c2c2c2; font-size: 20rpx; margin-top: 24rpx; margin-bottom: 20rpx; }

.icon { background-size: contain; background-repeat: no-repeat; background-position: center; }
