<view class="profile-page">
  <common-top-bar title="个人中心" showBack="{{false}}" />

  <scroll-view class="profile-scroll" scroll-y>
    <view class="user-card">
      <view class="bubble b1"></view>
      <view class="bubble b2"></view>
      <view class="card-top">
        <view class="user-left">
          <view class="avatar-box">
            <image class="avatar" src="{{userInfo.avatar || '../../assets/stitch/avatars/avatar-main.png'}}" mode="aspectFill" />
          </view>
          <view>
            <view class="name-row">
              <text class="name">{{userInfo.nickname || 'Lucky Dragon'}}</text>
              <view wx:if="{{!isGuest}}" class="edit-icon-btn" bindtap="goToEdit">
                <view class="icon icon-edit-name"></view>
              </view>
            </view>
            <view class="title-chip">
              <view class="icon icon-trophy-mini"></view>
              <text>{{userInfo.title || '小财神'}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="stats">
        <view class="stat split-r">
          <text class="v">{{userInfo.totalGames || 128}}</text>
          <text class="k">场次</text>
        </view>
        <view class="stat">
          <text class="v">{{userInfo.winRate || '45%'}} </text>
          <text class="k">胜率</text>
        </view>
      </view>
    </view>

    <view class="service-card">
      <text class="block-title">我的服务</text>
      <view class="service-grid">
        <view class="service-item"><view class="box red"><view class="icon icon-trophy"></view></view><text>我的战绩</text></view>
        <view class="service-item"><view class="box orange"><view class="icon icon-chart"></view></view><text>战绩榜</text></view>
        <view class="service-item"><view class="box yellow"><view class="icon icon-restore"></view></view><text>数据恢复</text></view>
        <view class="service-item"><view class="box green"><view class="icon icon-tag"></view></view><text>标签设置</text></view>
        <view class="service-item"><view class="box blue"><view class="icon icon-help"></view></view><text>使用帮助</text></view>
        <view class="service-item"><view class="box purple"><view class="icon icon-forum"></view></view><text>问题反馈</text></view>
        <view class="service-item"><view class="box teal"><view class="icon icon-support"></view></view><text>联系客服</text></view>
        <view class="service-item"><view class="box pink"><view class="icon icon-copy"></view></view><text>复制ID</text></view>
      </view>
    </view>

    <view class="menu-card">
      <view class="menu-item border"><view class="left"><view class="mini icon icon-share"></view><text>分享应用</text></view><view class="mini icon icon-arrow"></view></view>
      <view class="menu-item border"><view class="left"><view class="mini icon icon-qr"></view><text>物料码</text></view><view class="mini icon icon-arrow"></view></view>
      <view class="menu-item border"><view class="left"><view class="mini icon icon-font"></view><text>字体设置</text></view><view class="mini icon icon-arrow"></view></view>
      <view class="menu-item" bindtap="handleLogout"><view class="left"><view class="mini icon icon-logout"></view><text>{{isGuest ? '退出游客身份' : '退出登录'}}</text></view><view class="mini icon icon-arrow"></view></view>
    </view>

    <text class="version">v1.2.0 Build 2024</text>
  </scroll-view>
</view>
