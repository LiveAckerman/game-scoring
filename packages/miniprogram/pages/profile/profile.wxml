<page-meta page-style="{{pageFontStyle}}" />
<view class="profile-page">
  <common-top-bar title="个人中心" showBack="{{false}}" />

  <scroll-view class="profile-scroll" scroll-y>
    <view wx:if="{{showLoginCard}}" class="login-entry-card" bindtap="goToLogin">
      <view class="login-entry-main">
        <view class="login-entry-left">
          <view class="login-icon-wrap">
            <view class="icon icon-login"></view>
          </view>
          <view class="login-copy">
            <text class="login-title">登录后体验完整功能</text>
            <text class="login-sub">同步战绩、跨设备记录与更多个人设置</text>
          </view>
        </view>
        <view class="login-action">去登录</view>
      </view>
    </view>

    <view wx:else class="user-card">
      <view class="bubble b1"></view>
      <view class="bubble b2"></view>
      <view class="card-top">
        <view class="user-left">
          <view class="avatar-box">
            <image class="avatar" src="{{userInfo.avatar || '../../assets/stitch/avatars/avatar-main.jpg'}}" mode="aspectFill" />
          </view>
          <view>
            <view class="name-row">
              <text class="name">{{userInfo.nickname || 'Lucky Dragon'}}</text>
              <view wx:if="{{!isGuest}}" class="edit-icon-btn" bindtap="goToEdit">
                <view class="icon icon-edit-name"></view>
              </view>
            </view>
            <view class="title-chip">
              <view class="icon icon-trophy-mini"></view>
              <text>{{userInfo.title || '小财神'}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="stats-panel-head">
        <view class="stats-filter-copy">
          <text class="stats-title">战绩统计</text>
          <text class="stats-filter-label">{{userInfo.statsFilter.label || '全部数据'}}</text>
        </view>
        <view class="stats-setting-btn {{isGuest ? 'disabled' : ''}}" bindtap="openStatsFilterDialog">
          <view class="icon icon-stats-setting"></view>
        </view>
      </view>
      <view class="stats">
        <view class="stat split-r">
          <text class="v">{{userInfo.totalGames}}</text>
          <text class="k">场次</text>
        </view>
        <view class="stat">
          <text class="v">{{userInfo.winRate}} </text>
          <text class="k">胜率</text>
        </view>
      </view>
    </view>

    <view class="service-card">
      <text class="block-title">我的服务</text>
      <view class="service-grid">
        <view class="service-item" bindtap="goToMyRecords"><view class="box red"><view class="icon icon-trophy"></view></view><text>我的战绩</text></view>
        <view class="service-item" bindtap="goToLeaderboard"><view class="box orange"><view class="icon icon-chart"></view></view><text>战绩榜</text></view>
        <view class="service-item" bindtap="handleDataRestore"><view class="box yellow"><view class="icon icon-restore"></view></view><text>数据恢复</text></view>
        <view class="service-item" bindtap="goToTagSettings"><view class="box green"><view class="icon icon-tag"></view></view><text>标签设置</text></view>
        <view class="service-item" bindtap="goToSupport"><view class="box blue"><view class="icon icon-help"></view></view><text>使用帮助</text></view>
        <view class="service-item" bindtap="showFontSettings"><view class="box purple"><view class="icon icon-font-service"></view></view><text>字体设置</text></view>
        <view class="service-item" bindtap="goToSupport"><view class="box teal"><view class="icon icon-support"></view></view><text>使用建议</text></view>
        <view class="service-item" bindtap="showQrCode"><view class="box pink"><view class="icon icon-qr-service"></view></view><text>物料码</text></view>
      </view>
    </view>

    <view class="menu-card">
      <button class="menu-item border share-menu-btn" open-type="share">
        <view class="left"><view class="mini icon icon-share"></view><text>分享应用</text></view>
        <view class="mini icon icon-arrow"></view>
      </button>
      <view class="menu-item border" bindtap="goToVersionInfo"><view class="left"><view class="mini icon icon-version"></view><text>版本信息</text></view><view class="right-info"><text class="menu-meta">{{versionSummary}}</text><view class="mini icon icon-arrow"></view></view></view>
      <view class="menu-item" bindtap="handleLogout"><view class="left"><view class="mini icon icon-logout"></view><text>{{isGuest ? '退出游客身份' : '退出登录'}}</text></view><view class="mini icon icon-arrow"></view></view>
    </view>

    <!-- 物料码弹窗 -->
    <view class="popup-mask" wx:if="{{showQrPopup}}" bindtap="hideQrCode">
      <view class="popup-body" catchtap="">
        <text class="popup-title">小程序码</text>
        <text class="popup-desc">长按识别或扫描分享给好友</text>
        <image class="qr-preview" src="/assets/images/code.jpg" mode="aspectFit" show-menu-by-longpress="{{true}}" />
        <button class="popup-close-btn" bindtap="hideQrCode">关闭</button>
      </view>
    </view>

    <common-dialog
      visible="{{showStatsFilterDialog}}"
      title="统计维度"
      showClose="{{true}}"
      maskClosable="{{true}}"
      bind:close="closeStatsFilterDialog"
    >
      <view class="stats-filter-dialog">
        <text class="stats-filter-tip">默认展示全部数据，你也可以切换到某一年或某个月查看场次与胜率。</text>

        <view class="stats-scope-row">
          <view
            class="stats-scope-chip {{statsFilterDraftScope === 'ALL' ? 'active' : ''}}"
            data-scope="ALL"
            bindtap="selectStatsFilterScope"
          >全部</view>
          <view
            class="stats-scope-chip {{statsFilterDraftScope === 'YEAR' ? 'active' : ''}}"
            data-scope="YEAR"
            bindtap="selectStatsFilterScope"
          >按年</view>
          <view
            class="stats-scope-chip {{statsFilterDraftScope === 'MONTH' ? 'active' : ''}}"
            data-scope="MONTH"
            bindtap="selectStatsFilterScope"
          >按月</view>
        </view>

        <view wx:if="{{statsFilterDraftScope === 'YEAR'}}" class="stats-option-block">
          <text class="stats-option-title">选择年份</text>
          <view wx:if="{{userInfo.statsFilter.availableYears.length > 0}}" class="stats-option-grid">
            <view
              wx:for="{{userInfo.statsFilter.availableYears}}"
              wx:key="*this"
              class="stats-option-chip {{statsFilterDraftYear === item ? 'active' : ''}}"
              data-year="{{item}}"
              bindtap="selectStatsFilterYear"
            >{{item}}年</view>
          </view>
          <text wx:else class="stats-empty-text">暂无可筛选年份</text>
        </view>

        <view wx:if="{{statsFilterDraftScope === 'MONTH'}}" class="stats-option-block">
          <text class="stats-option-title">选择月份</text>
          <view wx:if="{{userInfo.statsFilter.availableMonths.length > 0}}" class="stats-option-grid month">
            <view
              wx:for="{{userInfo.statsFilter.availableMonths}}"
              wx:key="key"
              class="stats-option-chip month {{statsFilterDraftMonthKey === item.key ? 'active' : ''}}"
              data-month-key="{{item.key}}"
              bindtap="selectStatsFilterMonth"
            >{{item.label}}</view>
          </view>
          <text wx:else class="stats-empty-text">暂无可筛选月份</text>
        </view>
      </view>

      <view slot="footer" class="stats-dialog-footer">
        <button class="stats-dialog-btn ghost" bindtap="closeStatsFilterDialog">取消</button>
        <button class="stats-dialog-btn" bindtap="applyStatsFilter">应用</button>
      </view>
    </common-dialog>

    <text class="version">{{versionSummary}}</text>
  </scroll-view>
</view>
