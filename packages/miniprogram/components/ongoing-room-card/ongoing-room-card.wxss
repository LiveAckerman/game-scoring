.ongoing-room-card {
  background: linear-gradient(180deg, var(--c-surface-card), var(--c-surface-red));
  border-radius: 22rpx;
  border: 2rpx solid var(--c-border-soft);
  box-shadow: 0 10rpx 26rpx rgba(183,55,39,.1);
  padding: 22rpx 24rpx;
  box-sizing: border-box;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.head-main {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.room-code {
  font-size: var(--fs-base, 28rpx);
  line-height: 1.2;
  font-weight: 700;
  color: var(--c-text-primary);
}

.type-badge {
  flex-shrink: 0;
  font-size: 18rpx;
  min-height: 32rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
  line-height: 1;
  text-align: center;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.type-badge-text {
  line-height: 1;
  display: block;
}

.type-multi {
  background: var(--c-brand-red-soft);
  color: var(--c-brand-red-strong);
}

.type-single {
  background: var(--c-brand-gold-soft);
  color: var(--c-brand-gold-strong);
}

.type-pool {
  background: var(--c-surface-warm);
  color: var(--c-text-secondary);
}

.status-badge {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: var(--fs-xs, 20rpx);
  line-height: 1.2;
  font-weight: 700;
}

.status-badge.active {
  background: var(--c-success-bg);
  color: var(--c-success-fg);
}

.status-badge.ended {
  background: var(--c-danger-bg);
  color: var(--c-danger-fg);
}

.avatar-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
}

.avatar-item {
  width: 68rpx;
  height: 68rpx;
}

.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  border: 3rpx solid var(--c-surface-card);
  box-shadow: 0 6rpx 14rpx rgba(217, 48, 37, 0.12);
  box-sizing: border-box;
}

.avatar-text {
  background: linear-gradient(135deg, var(--c-brand-gold), var(--c-brand-red));
  color: var(--c-text-on-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-sm, 24rpx);
  font-weight: 700;
}
