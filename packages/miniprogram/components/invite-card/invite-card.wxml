<view class="invite-card">
  <view wx:if="{{showClose}}"  class="close-btn" bindtap="onCloseTap">
    <view class="icon icon-close"></view>
  </view>

  <view class="qr-wrap">
    <view class="qr-shell">
      <image class="qr" src="{{qrImageSrc}}" mode="aspectFit" />
    </view>
  </view>

  <text class="invite-tip">{{tipText}}</text>

  <view class="room-code-wrap" bindtap="onFocusCode">
    <view class="room-code-grid">
      <view wx:for="{{codeDigits}}" wx:key="index" class="code-cell {{roomCode.length === index ? 'active' : ''}}">
        <text class="code-char">{{item}}</text>
      </view>
    </view>
    <input
      wx:if="{{editable}}"
      class="hidden-room-input"
      type="number"
      maxlength="6"
      value="{{roomCode}}"
      focus="{{codeFocus}}"
      bindinput="onCodeInput"
      bindblur="onCodeBlur"
    />
  </view>

  <view class="room-btn-row {{!showJoinButton || !showCopyButton ? 'single' : ''}}">
    <button wx:if="{{showJoinButton}}" class="join-btn" bindtap="onJoinTap">{{joinButtonText}}</button>
    <button wx:if="{{showCopyButton}}" class="copy-btn" bindtap="onShareTap">{{copyButtonText}}</button>
  </view>

  <button wx:if="{{showShareButton}}" class="wx-share-btn" open-type="share">分享给好友</button>

</view>
