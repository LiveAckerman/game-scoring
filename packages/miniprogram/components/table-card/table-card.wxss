.table-card {
  background: linear-gradient(180deg, var(--c-surface-card), var(--c-surface-card-alt));
  border-radius: 24rpx;
  padding: 24rpx;
  border: 2rpx solid var(--c-border-soft);
  box-shadow: 0 10rpx 22rpx rgba(183,55,39,.08);
  margin-bottom: 16rpx;
}
.table-card.faded { opacity: .92; }

/* ---- header ---- */
.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}
.head-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.head-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.room-code {
  font-size: var(--fs-base, 28rpx);
  font-weight: 700;
  color: var(--c-text-primary);
}
.type-tag {
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
  line-height: 1.5;
}
.type-multi {
  background: var(--c-brand-red-soft);
  color: var(--c-brand-red-strong);
}
.type-single {
  background: var(--c-brand-gold-soft);
  color: var(--c-brand-gold-strong);
}
.type-pool {
  background: var(--c-surface-warm);
  color: var(--c-text-secondary);
}
.score-count {
  font-size: var(--fs-xs, 20rpx);
  color: var(--c-text-muted);
}
.status-badge {
  font-size: var(--fs-xs, 20rpx);
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
}
.status-badge.active {
  background: var(--c-success-bg);
  color: var(--c-success-fg);
}
.status-badge.ended {
  background: var(--c-danger-bg);
  color: var(--c-danger-fg);
}

/* ---- members ---- */
.members-row {
  display: flex;
  align-items: flex-start;
  gap: 26rpx;
  flex-wrap: wrap;
  margin-bottom: 14rpx;
}
.member-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 88rpx;
}
.avatar-wrap { position: relative; }
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  border: 3rpx solid var(--c-brand-red);
}
.avatar-text {
  background: linear-gradient(135deg, var(--c-brand-gold), var(--c-brand-red));
  color: var(--c-text-on-brand);
  border-color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-sm, 24rpx);
  font-weight: 700;
}
.host-tag {
  position: absolute;
  top: -8rpx;
  right: -10rpx;
  font-size: 16rpx;
  color: var(--c-text-on-brand);
  background: var(--c-brand-red);
  border-radius: 16rpx;
  padding: 2rpx 8rpx;
}
.member-name {
  font-size: var(--fs-xs, 20rpx);
  color: var(--c-text-secondary);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.member-score {
  font-size: var(--fs-xl, 38rpx);
  font-weight: 700;
  line-height: 1;
  display: block;
}
.member-score.pos { color: var(--c-brand-red); }
.member-score.neg { color: var(--c-text-primary); }
.member-score.zero { color: var(--c-text-muted); }

/* ---- footer ---- */
.card-foot {
  border-top: 2rpx solid var(--c-border-soft);
  padding-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.foot-time {
  font-size: var(--fs-xs, 20rpx);
  color: var(--c-text-muted);
}
.foot-my-score {
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-brand-red);
  font-weight: 700;
}

.tag-row {
  border-top: 2rpx dashed var(--c-border-soft);
  margin-top: 14rpx;
  padding-top: 16rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  flex: 1;
}

.tag-chip {
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 22rpx;
  border: 2rpx solid var(--c-brand-red);
  display: inline-flex;
  align-items: center;
  box-sizing: border-box;
  font-size: var(--fs-xs, 20rpx);
  font-weight: 700;
  background: var(--c-surface-card);
}

.tag-empty {
  font-size: var(--fs-xs, 20rpx);
  color: var(--c-text-muted);
  line-height: 44rpx;
}

.tag-action {
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: var(--c-brand-gold-soft);
  color: var(--c-brand-gold-strong);
  font-size: var(--fs-xs, 20rpx);
  font-weight: 700;
  flex-shrink: 0;
}
