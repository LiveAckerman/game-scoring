.topbar {
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 8rpx 18rpx rgba(183, 55, 39, 0.08);
  border-bottom: 2rpx solid rgba(199, 58, 45, 0.08);
}

.inner {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  position: relative;
}

.side {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  /* background: linear-gradient(135deg, var(--c-surface-card), var(--c-brand-gold-soft)); */
  /* border: 2rpx solid rgba(224, 161, 40, 0.2); */
  box-shadow: 0 6rpx 14rpx rgba(183, 55, 39, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  color: inherit;
}

.back-arrow {
  font-size: 58rpx;
  line-height: 1;
  font-weight: 500;
  margin-top: -4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: var(--fs-xl, 38rpx);
  font-weight: 700;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 6rpx rgba(255, 248, 242, 0.42);
  max-width: 60%;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
