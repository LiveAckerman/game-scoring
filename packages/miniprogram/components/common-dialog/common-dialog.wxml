<view wx:if="{{visible}}" class="dialog-mask" bindtap="onMaskTap">
  <view class="dialog-panel" catchtap="stopPropagation">
    <view class="dialog-head" wx:if="{{title || showClose}}">
      <text class="dialog-title">{{title}}</text>
      <view wx:if="{{showClose}}" class="close-btn" bindtap="onCloseTap">
        <view class="icon icon-close"></view>
      </view>
    </view>

    <scroll-view class="dialog-body-scroll" scroll-y>
      <view class="dialog-body">
        <slot></slot>
      </view>
    </scroll-view>

    <view wx:if="{{showFooter}}" class="dialog-footer">
      <button class="footer-btn ghost" bindtap="onCancelTap">{{cancelText}}</button>
      <button class="footer-btn" bindtap="onConfirmTap">{{confirmText}}</button>
    </view>

    <view wx:else class="dialog-footer-slot">
      <slot name="footer"></slot>
    </view>
  </view>
</view>
