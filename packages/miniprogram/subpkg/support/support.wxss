.support-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(224, 161, 40, 0.18), transparent 26%),
    linear-gradient(180deg, var(--c-surface-app) 0%, var(--c-surface-warm) 100%);
  display: flex;
  flex-direction: column;
}

.support-scroll {
  flex: 1;
  padding: 20rpx 24rpx 200rpx;
  box-sizing: border-box;
}

.hero-card,
.faq-card,
.tips-card {
  background: rgba(255, 253, 249, 0.96);
  border-radius: 28rpx;
  box-shadow: 0 14rpx 36rpx rgba(183, 55, 39, 0.08);
  border: 2rpx solid var(--c-border-soft);
}

.hero-card {
  position: relative;
  overflow: hidden;
  padding: 30rpx 30rpx 34rpx;
  margin-bottom: 20rpx;
}

.hero-card::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -36rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(224, 161, 40, 0.18);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 116rpx;
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 23rpx;
  background: var(--c-surface-gold);
  color: var(--c-brand-gold-strong);
  font-size: var(--fs-xs, 20rpx);
  font-weight: 700;
  margin-bottom: 16rpx;
}

.hero-title {
  display: block;
  width: 86%;
  font-size: var(--fs-xl, 38rpx);
  line-height: 1.35;
  font-weight: 700;
  color: var(--c-text-primary);
  margin-bottom: 12rpx;
  word-break: break-word;
}

.hero-desc {
  display: block;
  width: 80%;
  font-size: var(--fs-sm, 24rpx);
  line-height: 1.6;
  color: var(--c-text-secondary);
  word-break: break-word;
}

.faq-card,
.tips-card {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.section-title {
  display: block;
  font-size: var(--fs-md, 30rpx);
  font-weight: 700;
  color: var(--c-text-primary);
  margin-bottom: 18rpx;
}

.faq-panel {
  border-radius: 22rpx;
  overflow: hidden;
  margin-bottom: 14rpx;
  border: 2rpx solid var(--c-border-soft);
  background: var(--c-surface-card);
}

.faq-panel:last-child {
  margin-bottom: 0;
}

.faq-index {
  color: var(--c-brand-red);
  font-size: var(--fs-base, 28rpx);
  font-weight: 700;
  flex-shrink: 0;
}

.faq-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx 22rpx;
  background: linear-gradient(180deg, var(--c-surface-card) 0%, var(--c-surface-red) 100%);
}

.faq-head-main {
  flex: 1;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  min-width: 0;
}

.faq-title {
  font-size: var(--fs-base, 28rpx);
  color: var(--c-text-primary);
  font-weight: 700;
  line-height: 1.5;
  word-break: break-word;
}

.faq-arrow {
  width: 18rpx;
  height: 18rpx;
  border-right: 4rpx solid var(--c-text-muted);
  border-bottom: 4rpx solid var(--c-text-muted);
  transform: rotate(45deg);
  transition: transform 0.2s ease;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.faq-arrow.expanded {
  transform: rotate(225deg);
  margin-top: 10rpx;
}

.faq-body {
  background: var(--c-surface-warm);
  padding: 26rpx 30rpx;
}

.faq-desc,
.tip-line {
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-text-secondary);
  line-height: 1.6;
}

.faq-desc {
  color: var(--c-text-secondary);
  word-break: break-word;
}

.faq-empty {
  padding: 20rpx 0;
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-text-muted);
  text-align: center;
}

.support-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: rgba(255, 246, 238, 0.96);
  backdrop-filter: blur(12rpx);
  box-sizing: border-box;
  border-top: 2rpx solid var(--c-border-soft);
}

.contact-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, var(--c-brand-red), var(--c-brand-gold));
  color: var(--c-text-on-brand);
  font-size: var(--fs-base, 28rpx);
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 0 12rpx;
  padding: 0;
  border: none;
}

.contact-btn::after {
  border: none;
}

.footer-note {
  display: block;
  text-align: center;
  font-size: var(--fs-xs, 20rpx);
  color: var(--c-text-muted);
  line-height: 1.5;
}
