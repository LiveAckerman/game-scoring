<page-meta page-style="{{pageFontStyle}}" />
<view class="support-page">
  <common-top-bar title="联系客服" bind:back="goBack" />

  <scroll-view class="support-scroll" scroll-y>
    <view class="hero-card">
      <view class="hero-badge">Guide</view>
      <text class="hero-title">使用说明</text>
      <text class="hero-desc">整理了常见牌桌模式、旁观权限和异常处理方式。点开问题即可查看详细说明。</text>
    </view>

    <view class="faq-card">
      <text class="section-title">常见问题</text>
      <view wx:if="{{faqs.length === 0}}" class="faq-empty">暂无常见问题，请直接联系客服。</view>
      <block wx:else>
        <view wx:for="{{faqs}}" wx:key="id" class="faq-panel">
          <view class="faq-head" bindtap="toggleFaq" data-id="{{item.id}}">
            <view class="faq-head-main">
              <text class="faq-index">{{index + 1}}.</text>
              <text class="faq-title">{{item.title}}</text>
            </view>
            <view class="faq-arrow {{item.expanded ? 'expanded' : ''}}"></view>
          </view>
          <view wx:if="{{item.expanded}}" class="faq-body">
            <text class="faq-desc">{{item.desc}}</text>
          </view>
        </view>
      </block>
    </view>

    <view class="tips-card">
      <text class="section-title">联系客服前建议准备</text>
      <text class="tip-line">房间号 / 问题发生时间 / 玩家昵称 / 错误提示截图</text>
      <text class="tip-line">描述越具体，客服定位问题会越快。</text>
    </view>
  </scroll-view>

  <view class="support-footer">
    <button class="contact-btn" open-type="contact" show-message-card="{{true}}">
      联系人工客服
    </button>
  </view>
</view>
