<page-meta page-style="{{pageFontStyle}}" />
<view class="edit-page">
  <common-top-bar title="编辑资料" bind:back="goBack" />

  <scroll-view class="edit-scroll" scroll-y>
    <view class="avatar-section">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <view class="avatar-shell">
          <view class="avatar-ring">
            <image class="avatar" src="{{avatarTempPath || userInfo.avatar || '../../assets/stitch/avatars/avatar-main.png'}}" mode="aspectFill" />
          </view>
          <view class="camera-btn"><view class="icon icon-camera"></view></view>
        </view>
      </button>
      <text class="hint">点击更换头像</text>
    </view>

    <view class="form-group">
      <view class="label-row">
        <text class="label">昵称</text>
        <text class="quick-link" bindtap="focusNickname">点击输入时可选微信昵称</text>
      </view>
      <view class="input-box">
        <input
          class="input"
          type="nickname"
          value="{{userInfo.nickname}}"
          placeholder="请输入昵称（键盘上方可选微信昵称）"
          focus="{{nicknameFocus}}"
          bindfocus="onNicknameFocus"
          bindblur="onNicknameBlur"
          bindinput="onNicknameInput"
        />
        <view class="icon icon-edit" catchtap="focusNickname"></view>
      </view>
    </view>

    <view class="form-group">
      <text class="label">性别</text>
      <view class="gender-row">
        <view class="gender-card male {{userInfo.gender === 1 ? 'active' : ''}}" data-val="1" bindtap="setGender">
          <view class="icon icon-male"></view>
          <text>男</text>
        </view>
        <view class="gender-card female {{userInfo.gender === 2 ? 'active' : ''}}" data-val="2" bindtap="setGender">
          <view class="icon icon-female"></view>
          <text>女</text>
        </view>
      </view>
    </view>

    <view class="form-group">
      <view class="label-row">
        <text class="label">称号</text>
        <text class="all">查看全部</text>
      </view>

      <view class="title-grid">
        <view class="title-item on {{userInfo.title === '小财神' ? 'active' : ''}}" data-val="小财神" bindtap="setTitle">
          <view class="icon-wrap gold"><view class="icon icon-trophy"></view></view>
          <view class="txt">
            <text class="name">小财神</text>
            <text class="desc">当前佩戴</text>
          </view>
          <view class="icon icon-check" wx:if="{{userInfo.title === '小财神'}}"></view>
        </view>

        <view class="title-item lock" data-val="常胜将军" bindtap="setTitle">
          <view class="icon-wrap red"><view class="icon icon-fire"></view></view>
          <view class="txt"><text class="name">常胜将军</text><text class="desc">需胜率60%</text></view>
        </view>

        <view class="title-item lock" data-val="运气王" bindtap="setTitle">
          <view class="icon-wrap purple"><view class="icon icon-star"></view></view>
          <view class="txt"><text class="name">运气王</text><text class="desc">暂未解锁</text></view>
        </view>

        <view class="title-item lock" data-val="至尊VIP" bindtap="setTitle">
          <view class="icon-wrap blue"><view class="icon icon-diamond"></view></view>
          <view class="txt"><text class="name">至尊VIP</text><text class="desc">会员专属</text></view>
        </view>
      </view>
    </view>

    <button class="save" bindtap="handleSave" loading="{{saving}}" disabled="{{saving}}">
      <view class="icon icon-save"></view>
      <text>保存修改</text>
    </button>
  </scroll-view>
</view>
