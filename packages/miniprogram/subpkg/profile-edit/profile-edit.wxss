.edit-page { min-height: 100vh; background: #fff5f5; display: flex; flex-direction: column; }
.edit-scroll { flex: 1; padding: 28rpx 24rpx 30rpx; box-sizing: border-box; }
.avatar-section { display: flex; flex-direction: column; align-items: center; margin-bottom: 34rpx; }
.avatar-shell { position: relative; }
.avatar-ring { width: 220rpx; height: 220rpx; border-radius: 110rpx; background: linear-gradient(135deg,#d93025,#ff6f00); padding: 8rpx; box-sizing: border-box; }
.avatar { width: 100%; height: 100%; border-radius: 106rpx; border: 6rpx solid #fff; }
.camera-btn { position: absolute; right: 0; bottom: 0; width: 66rpx; height: 66rpx; border-radius: 33rpx; background: #ffd700; border: 4rpx solid #fff; display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 18rpx rgba(0,0,0,.12); }
.hint { margin-top: 10rpx; font-size: 22rpx; color: #969696; }
.form-group { margin-bottom: 24rpx; }
.label { display: block; font-size: 30rpx; font-weight: 700; color: #333; margin-bottom: 14rpx; }
.quick-link { font-size: 22rpx; color: #d93025; font-weight: 700; }
.input-box { background: #fff; border-radius: 24rpx; padding: 0 24rpx; display: flex; align-items: center; height: 96rpx; }
.input { flex: 1; font-size: 30rpx; color: #333; }
.gender-row { display: flex; gap: 16rpx; }
.gender-card { flex: 1; background: #fff; border-radius: 24rpx; border: 4rpx solid transparent; height: 132rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx; font-size: 26rpx; font-weight: 700; color: #555; }
.gender-card.active.male { border-color: #3b82f6; background: #eff6ff; color: #2563eb; }
.gender-card.active.female { border-color: #ec4899; background: #fdf2f8; color: #db2777; }
.label-row { display: flex; justify-content: space-between; align-items: center; }
.all { font-size: 22rpx; color: #d93025; font-weight: 700; }
.title-grid { margin-top: 10rpx; display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; }
.title-item { background: #fff; border-radius: 20rpx; border: 3rpx solid transparent; padding: 14rpx; display: flex; align-items: center; gap: 12rpx; position: relative; }
.title-item.on.active { border-color: #ffd700; background: #fffdf4; }
.title-item.lock { opacity: .6; filter: grayscale(100%); }
.icon-wrap { width: 62rpx; height: 62rpx; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; }
.icon-wrap.gold { background: #fff7cc; }
.icon-wrap.red { background: #ffeaea; }
.icon-wrap.purple { background: #f3e8ff; }
.icon-wrap.blue { background: #e6f0ff; }
.txt { display: flex; flex-direction: column; }
.name { font-size: 24rpx; color: #d93025; font-weight: 700; }
.desc { font-size: 18rpx; color: #999; }
.save { margin-top: 12rpx; width: 100%; height: 96rpx; border-radius: 48rpx; background: linear-gradient(90deg,#d93025,#ef4444); color: #fff; display: flex; align-items: center; justify-content: center; gap: 10rpx; font-size: 30rpx; font-weight: 700; box-shadow: 0 10rpx 24rpx rgba(217,48,37,.24); }
.save::after { border: none; }

.icon { background-size: contain; background-repeat: no-repeat; background-position: center; }
