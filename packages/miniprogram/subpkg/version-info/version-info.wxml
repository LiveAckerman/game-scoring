<page-meta page-style="{{pageFontStyle}}" />
<view class="version-page">
  <common-top-bar title="版本信息" bind:back="goBack" />

  <scroll-view class="version-scroll" scroll-y>
    <view class="current-card">
      <view class="current-row">
        <text class="current-label">当前版本</text>
        <text class="env-badge">{{envVersionLabel}}</text>
      </view>
      <text class="current-version">v{{currentVersion}}</text>
      <text class="current-desc">版本号可用于核对当前小程序发布版本；更新历史由应用内版本日志维护。</text>
    </view>

    <view class="history-card">
      <text class="section-title">版本历史</text>
      <view wx:for="{{history}}" wx:key="version" class="history-item">
        <view class="history-head">
          <view>
            <text class="history-version">v{{item.version}}</text>
            <text class="history-title">{{item.title}}</text>
          </view>
          <text class="history-date">{{item.releaseDate}}</text>
        </view>
        <view wx:for="{{item.changes}}" wx:key="*this" class="history-line">
          <text class="history-dot"></text>
          <text class="history-text">{{item}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
