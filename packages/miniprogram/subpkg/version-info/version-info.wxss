.version-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(224, 161, 40, 0.18), transparent 24%),
    linear-gradient(180deg, var(--c-surface-app) 0%, var(--c-surface-warm) 100%);
  display: flex;
  flex-direction: column;
}

.version-scroll {
  flex: 1;
  padding: 20rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.current-card,
.history-card {
  background: rgba(255, 253, 249, 0.96);
  border-radius: 28rpx;
  border: 2rpx solid var(--c-border-soft);
  box-shadow: 0 14rpx 32rpx rgba(183, 55, 39, 0.08);
}

.current-card {
  padding: 28rpx;
  margin-bottom: 18rpx;
}

.current-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.current-label {
  font-size: var(--fs-base, 28rpx);
  color: var(--c-text-muted);
  font-weight: 700;
}

.env-badge {
  min-width: 112rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 22rpx;
  padding: 0 16rpx;
  background: var(--c-surface-gold);
  color: var(--c-brand-gold-strong);
  font-size: var(--fs-xs, 20rpx);
  font-weight: 700;
  box-sizing: border-box;
}

.current-version {
  display: block;
  font-size: 54rpx;
  line-height: 1.1;
  color: var(--c-brand-red);
  font-weight: 700;
  margin-bottom: 12rpx;
}

.latest-version {
  display: block;
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-brand-gold-strong);
  font-weight: 700;
  margin-bottom: 12rpx;
}

.current-desc {
  display: block;
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-text-secondary);
  line-height: 1.6;
}

.load-error {
  display: block;
  margin-top: 10rpx;
  font-size: var(--fs-xs, 20rpx);
  color: var(--c-danger-fg);
}

.history-card {
  padding: 24rpx;
}

.section-title {
  display: block;
  font-size: var(--fs-md, 30rpx);
  color: var(--c-text-primary);
  font-weight: 700;
  margin-bottom: 16rpx;
}

.history-item {
  padding: 22rpx 0;
  border-bottom: 2rpx solid var(--c-border-soft);
}

.history-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.history-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.history-title-wrap {
  min-width: 0;
  flex: 1;
}

.history-version {
  display: block;
  font-size: var(--fs-base, 28rpx);
  color: var(--c-text-primary);
  font-weight: 700;
  margin-bottom: 4rpx;
  word-break: break-word;
}

.history-title {
  display: block;
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-brand-gold-strong);
  font-weight: 700;
  word-break: break-word;
}

.history-date {
  font-size: var(--fs-xs, 20rpx);
  color: var(--c-text-muted);
  flex-shrink: 0;
  margin-top: 4rpx;
}

.history-line {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.history-line:last-child {
  margin-bottom: 0;
}

.history-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 5rpx;
  background: var(--c-brand-red);
  margin-top: 12rpx;
  flex-shrink: 0;
}

.history-text {
  flex: 1;
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-text-secondary);
  line-height: 1.6;
  word-break: break-word;
}

.history-loading,
.history-empty {
  padding: 18rpx 0;
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-text-muted);
  text-align: center;
}

.retry-card {
  margin-top: 18rpx;
  padding: 20rpx 24rpx;
  border-radius: 22rpx;
  background: var(--c-surface-warm);
  border: 2rpx solid var(--c-border-soft);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.retry-text {
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-text-secondary);
  line-height: 1.5;
  flex: 1;
  min-width: 0;
}

.retry-btn {
  flex-shrink: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  background: var(--c-brand-red);
  color: var(--c-text-on-brand);
  font-size: var(--fs-sm, 24rpx);
  font-weight: 700;
  border: none;
}

.retry-btn::after {
  border: none;
}
