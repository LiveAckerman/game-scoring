<page-meta page-style="{{pageFontStyle}}" />
<view class="invite-page">
  <view class="bg-confetti"></view>

  <common-top-bar title="{{topBarTitle}}" bind:back="goBack" />

  <scroll-view class="content" scroll-y>
    <!-- 分数池模式操作栏 -->
    <view wx:if="{{isPoolMode}}" class="action-strip-wrap">
      <view class="action-strip-shadow"></view>
      <view class="action-strip">
        <view class="action-strip-head">
          <text class="action-strip-title">牌桌操作</text>
          <view class="room-status-chip {{roomStatus === 'IN_PROGRESS' ? 'active' : 'ended'}}">
            <text>{{roomStatus === 'IN_PROGRESS' ? '进行中' : '已结束'}}</text>
          </view>
        </view>
        <view class="action-strip-grid pool-action-grid">
          <view wx:if="{{isOwner && roomStatus === 'IN_PROGRESS'}}" class="action-item" bindtap="onActionTap" data-action="manage">
            <view class="action-icon"><view class="icon icon-settings"></view></view>
            <text>牌桌管理</text>
          </view>
          <view class="action-item {{!isOwner ? 'disabled' : ''}}" bindtap="handleToggleTableFee">
            <view class="action-icon"><view class="icon icon-board"></view></view>
            <text>{{tableFeeEnabled ? '台板已开' : '台板未开'}}</text>
          </view>
          <view
            class="action-item {{!isOwner || roomStatus !== 'IN_PROGRESS' ? 'disabled' : ''}}"
            bindtap="onActionTap"
            data-action="end"
          >
            <view class="action-icon"><view class="icon icon-power"></view></view>
            <text>结束本桌</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 多人模式操作栏 -->
    <view wx:else class="action-strip-wrap">
      <view class="action-strip-shadow"></view>
      <view class="action-strip">
        <view class="action-strip-head">
          <text class="action-strip-title">房间操作</text>
          <view class="room-status-chip {{roomStatus === 'IN_PROGRESS' ? 'active' : 'ended'}}">
            <text>{{roomStatus === 'IN_PROGRESS' ? '进行中' : '已结束'}}</text>
          </view>
        </view>
        <view class="action-strip-grid multi-action-grid">
          <view class="action-item" bindtap="onActionTap" data-action="invite">
            <view class="action-icon"><view class="icon icon-invite"></view></view>
            <text>邀请</text>
          </view>
          <view
            class="action-item {{!isOwner || roomStatus !== 'IN_PROGRESS' ? 'disabled' : ''}}"
            bindtap="handleToggleTableFee"
          >
            <view class="action-icon"><view class="icon icon-board"></view></view>
            <text>{{tableFeeEnabled ? '台板已开' : '台板未开'}}</text>
          </view>
        <view
          class="action-item {{isOwner && roomStatus !== 'IN_PROGRESS' ? 'disabled' : ''}}"
          bindtap="onActionTap"
          data-action="{{isOwner ? 'end' : (currentMemberIsSpectator && roomStatus === 'IN_PROGRESS' ? 'cancel-spectator' : 'leave')}}"
        >
          <view class="action-icon"><view class="icon icon-power"></view></view>
          <text>{{isOwner ? '结束' : (currentMemberIsSpectator && roomStatus === 'IN_PROGRESS' ? '取消旁观' : '退出')}}</text>
        </view>
          <view class="action-item" bindtap="onActionTap" data-action="mute">
            <view class="action-icon"><view class="icon icon-mute"></view></view>
            <text>{{ttsMuted ? '开启' : '播报'}}</text>
          </view>

          <view wx:if="{{isOwner && roomStatus === 'IN_PROGRESS'}}" class="action-item" bindtap="onActionTap" data-action="settings">
            <view class="action-icon"><view class="icon icon-settings"></view></view>
            <text>牌桌管理</text>
          </view>
        </view>
      </view>
    </view>

    <invite-card
      wx:if="{{showInlineInviteCard}}"
      roomCode="{{roomCode}}"
      codeDigits="{{codeDigits}}"
      codeFocus="{{codeFocus}}"
      roomStatus="{{roomStatus}}"
      qrImageSrc="/assets/images/code.jpg"
      showClose="{{true}}"
      editable="{{false}}"
      showJoinButton="{{false}}"
      showCopyButton="{{true}}"
      showShareButton="{{true}}"
      tipText="房间号仅用于分享邀请，加入操作请在首页完成"
      bind:share="handleShareInvite"
      bind:close="handleInlineInviteCardClose"
    />

    <view class="player-section {{showInlineInviteCard ? '' : 'tight-top'}}">
      <view class="player-head"><text>玩家数量: {{displayMemberCount}}</text></view>

      <view
        wx:for="{{members}}"
        wx:key="id"
        class="player-card {{item.id === currentMemberId ? 'self' : ''}} {{item.isSpectator ? 'spectator' : ''}}"
      >
        <view class="avatar-wrap">
          <view wx:if="{{item.actorType === 'VIRTUAL' && item.nickname === '台板'}}" class="avatar table-icon">
            <text class="table-icon-text">台</text>
          </view>
          <image wx:elif="{{item.avatar}}" class="avatar" src="{{item.avatar}}" mode="aspectFill" />
          <view wx:else class="avatar avatar-text"><text>{{item.avatarInitials || '游客'}}</text></view>
          <text wx:if="{{item.isOwner}}" class="host-tag">桌主</text>
          <text wx:if="{{item.isSpectator}}" class="spectator-tag">旁观</text>
        </view>

        <view class="player-info">
          <view class="name-row">
            <text class="player-name">{{item.nickname}}</text>
            <text wx:if="{{item.id === currentMemberId}}" class="self-tag">我</text>
          </view>
          <text class="player-desc">{{item.actorType === 'VIRTUAL' && item.nickname === '台板' ? '台板账户' : (item.isOwner ? '房间管理员' : (item.isSpectator ? '旁观者' : '普通玩家'))}}</text>
        </view>

        <view class="score-wrap">
          <text class="score {{item.score >= 0 ? 'pos' : 'neg'}}">{{item.score}}</text>
          <text class="score-label">积分</text>
        </view>

        <view
          class="member-actions"
          wx:if="{{!isPoolMode && !currentMemberIsSpectator && item.id !== currentMemberId && !item.isSpectator}}"
        >
          <view
            class="tiny-btn give-btn"
            bindtap="openScoreDialog"
            data-member-id="{{item.id}}"
            data-member-name="{{item.nickname}}"
            disabled="{{roomStatus !== 'IN_PROGRESS'}}"
          >给分</view>
          <view
            wx:if="{{isOwner && item.actorType === 'VIRTUAL' && item.nickname === '台板' && roomStatus === 'IN_PROGRESS' && item.score > 0}}"
            class="tiny-btn refund-btn"
            bindtap="handleRefundTableFee"
            data-member-id="{{item.id}}"
            data-member-name="{{item.nickname}}"
            data-member-score="{{item.score}}"
          >退分</view>
        </view>

        <view
          class="member-actions"
          wx:if="{{item.id === currentMemberId && item.isSpectator && roomStatus === 'IN_PROGRESS' && !isOwner}}"
        >
          <view class="tiny-btn spectator-exit-btn" bindtap="handleCancelSpectator">取消旁观</view>
        </view>
      </view>

      <view wx:if="{{members.length === 0}}" class="empty-seat">
        <view class="icon icon-person-outline"></view>
        <text>虚位以待</text>
      </view>
    </view>

    <!-- 分数池模式：圈次统计表 -->
    <view wx:if="{{isPoolMode && poolRounds.length > 0}}" class="pool-stats-card">
      <scroll-view class="pool-stats-scroll" scroll-x enable-flex="true">
        <view class="pool-stats-table" style="min-width: {{poolStatsTableWidth}}rpx;">
          <view class="pool-stats-head">
            <view class="pool-stats-cell head-cell">圈数</view>
            <view wx:for="{{poolStatsMembers}}" wx:for-item="pm" wx:key="id" class="pool-stats-cell head-cell">
              <view wx:if="{{pm.actorType === 'VIRTUAL' && pm.nickname === '台板'}}" class="mini-table-icon">
                <text>台</text>
              </view>
              <image wx:elif="{{pm.avatar}}" class="mini-avatar" src="{{pm.avatar}}" mode="aspectFill" />
              <view wx:else class="mini-avatar mini-avatar-text"><text>{{pm.avatarInitials}}</text></view>
            </view>
          </view>
          <view class="pool-stats-row winrate-row">
            <view class="pool-stats-cell label-cell">胜率</view>
            <view wx:for="{{poolStatsMembers}}" wx:for-item="pm" wx:key="id" class="pool-stats-cell">
              <text>{{pm.winRate || '0%'}}</text>
            </view>
          </view>
          <view
            wx:for="{{poolRounds}}"
            wx:for-item="rd"
            wx:key="id"
            class="pool-stats-row clickable"
            bindtap="goToRoundDetail"
            data-round-id="{{rd.id}}"
          >
            <view class="pool-stats-cell label-cell">
              <text class="round-time">{{rd.timeText}}</text>
              <text>第{{rd.roundNumber}}圈</text>
            </view>
            <view wx:for="{{poolStatsMembers}}" wx:for-item="pm" wx:key="id" class="pool-stats-cell">
              <text>{{rd.memberScoreMap[pm.id] || '-'}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 多人模式：记分明细 -->
    <view wx:if="{{!isPoolMode}}" class="records-section">
      <score-record-list
        records="{{scoreRecords}}"
        normalActionText="给了"
      />
    </view>
  </scroll-view>

  <view wx:if="{{settingsSheetVisible}}" class="settings-sheet-mask" bindtap="closeSettingsSheet">
    <view class="settings-sheet" catchtap="noop">
      <view class="settings-sheet-list">
        <view class="settings-sheet-item" bindtap="handleSettingsOptionTap" data-action="room-name">设置牌桌名称</view>
        <view class="settings-sheet-item" bindtap="handleSettingsOptionTap" data-action="transfer-owner">转移桌主身份</view>
        <view class="settings-sheet-item" bindtap="handleSettingsOptionTap" data-action="spectators">旁观者设置</view>
        <view class="settings-sheet-item danger" bindtap="handleSettingsOptionTap" data-action="kick-member">踢出玩家</view>
      </view>
      <view class="settings-sheet-cancel" bindtap="closeSettingsSheet">取消</view>
    </view>
  </view>

  <!-- 分数池模式：底部按钮 -->
  <view wx:if="{{isPoolMode && roomStatus === 'IN_PROGRESS'}}" class="pool-bottom-bar">
    <view wx:if="{{activePoolRound}}" class="pool-bottom-btn active" bindtap="goToPoolRecord">
      第 {{activePoolRound.roundNumber}} 圈正在记录中，点击进入
    </view>
    <view wx:elif="{{isOwner}}" class="pool-bottom-btn" bindtap="handleStartPoolRound">
      开启新的一圈
    </view>
  </view>

  <common-dialog
    visible="{{invitePopupVisible}}"
    title="邀请好友加入"
    showClose="{{true}}"
    maskClosable="{{true}}"
    bind:close="closeInvitePopup"
  >
    <invite-card
      roomCode="{{roomCode}}"
      codeDigits="{{codeDigits}}"
      codeFocus="{{codeFocus}}"
      roomStatus="{{roomStatus}}"
      qrImageSrc="/assets/images/code.jpg"
      showClose="{{false}}"
      editable="{{false}}"
      showJoinButton="{{false}}"
      showCopyButton="{{true}}"
      tipText="复制房间号，发送给好友在首页加入"
      bind:share="handleShareInvite"
    />
    <view slot="footer" class="invite-popup-footer">
      <button class="invite-popup-btn ghost" bindtap="handleShareInvite">复制房间号</button>
      <button class="invite-popup-btn" open-type="share">微信分享</button>
    </view>
  </common-dialog>

  <common-dialog
    visible="{{roomNameDialogVisible}}"
    title="设置牌桌名称"
    showClose="{{false}}"
    maskClosable="{{true}}"
    bind:close="closeRoomNameDialog"
  >
    <view class="manage-dialog-body">
      <text class="manage-dialog-desc">设置后，本页顶部标题和分享文案都会同步为新的牌桌名称。</text>
      <input
        class="manage-name-input"
        value="{{roomNameDraft}}"
        maxlength="64"
        focus="{{roomNameDialogVisible}}"
        placeholder="请输入牌桌名称，不填则恢复默认桌号"
        bindinput="onRoomNameInput"
      />
    </view>
    <view slot="footer" class="manage-footer">
      <button class="manage-footer-btn ghost" bindtap="closeRoomNameDialog">取消</button>
      <button class="manage-footer-btn" bindtap="confirmRoomNameDialog">确定</button>
    </view>
  </common-dialog>

  <common-dialog
    visible="{{transferDialogVisible}}"
    title="转移桌主身份"
    showClose="{{false}}"
    maskClosable="{{true}}"
    bind:close="closeTransferDialog"
  >
    <view class="manage-dialog-body">
      <text class="manage-dialog-desc">请选择新的桌主，桌主可继续管理牌桌、调整旁观者并结束本桌。</text>
      <view class="manage-candidate-grid">
        <view
          wx:for="{{transferCandidates}}"
          wx:key="id"
          class="manage-candidate-item {{item.selected ? 'selected' : ''}}"
          bindtap="selectTransferCandidate"
          data-member-id="{{item.id}}"
        >
          <view class="manage-avatar-wrap">
            <image wx:if="{{item.avatar}}" class="manage-avatar" src="{{item.avatar}}" mode="aspectFill" />
            <view wx:else class="manage-avatar manage-avatar-text"><text>{{item.avatarInitials || '游客'}}</text></view>
            <view wx:if="{{item.selected}}" class="manage-candidate-check">✓</view>
          </view>
          <text class="manage-candidate-name">{{item.nickname}}</text>
        </view>
      </view>
    </view>
    <view slot="footer" class="manage-footer">
      <button class="manage-footer-btn ghost" bindtap="closeTransferDialog">取消</button>
      <button class="manage-footer-btn" bindtap="confirmTransferDialog">确定</button>
    </view>
  </common-dialog>

  <common-dialog
    visible="{{kickDialogVisible}}"
    title="踢出玩家"
    showClose="{{false}}"
    maskClosable="{{true}}"
    bind:close="closeKickDialog"
  >
    <view class="manage-dialog-body">
      <text class="manage-dialog-desc">仅可踢出无得失分记录的玩家，不能踢出桌主或台板成员。</text>
      <view class="manage-candidate-grid">
        <view
          wx:for="{{kickCandidates}}"
          wx:key="id"
          class="manage-candidate-item {{item.selected ? 'selected' : ''}}"
          bindtap="selectKickCandidate"
          data-member-id="{{item.id}}"
        >
          <view class="manage-avatar-wrap">
            <image wx:if="{{item.avatar}}" class="manage-avatar" src="{{item.avatar}}" mode="aspectFill" />
            <view wx:else class="manage-avatar manage-avatar-text"><text>{{item.avatarInitials || '游客'}}</text></view>
            <view wx:if="{{item.selected}}" class="manage-candidate-check">✓</view>
          </view>
          <text class="manage-candidate-name">{{item.nickname}}</text>
        </view>
      </view>
    </view>
    <view slot="footer" class="manage-footer">
      <button class="manage-footer-btn ghost" bindtap="closeKickDialog">取消</button>
      <button class="manage-footer-btn danger" bindtap="confirmKickDialog">确定</button>
    </view>
  </common-dialog>

  <common-dialog
    visible="{{scoreNotifyDialogVisible}}"
    title="语音播报设置"
    showClose="{{false}}"
    maskClosable="{{true}}"
    bind:close="closeScoreNotifyDialog"
  >
    <view class="score-notify-dialog">
      <text class="score-notify-desc">开启后，仅在你收到积分时播放语音提醒</text>
      <text class="score-notify-status {{ttsMuted ? 'off' : 'on'}}">
        {{ttsMuted ? '当前状态：已关闭' : '当前状态：已开启'}}
      </text>

      <view class="score-notify-list">
        <view
          wx:for="{{scoreNotifyVoiceOptions}}"
          wx:key="value"
          class="score-notify-item"
          bindtap="selectScoreNotifyVoice"
          data-voice="{{item.value}}"
        >
          <text class="score-notify-name">{{item.name}}</text>
          <view
            class="score-notify-preview-btn"
            catchtap="previewScoreNotifyVoice"
            data-voice="{{item.value}}"
          >
            <text>试听</text>
          </view>
          <text wx:if="{{item.value === ttsVoice}}" class="score-notify-check">✓</text>
        </view>
      </view>
    </view>

    <view slot="footer" class="score-notify-footer">
      <button class="score-notify-footer-btn ghost" bindtap="closeScoreNotifyDialog">取消</button>
      <button class="score-notify-footer-btn" bindtap="confirmScoreNotifyDialog">
        {{ttsMuted ? '开启播报' : '关闭播报'}}
      </button>
    </view>
  </common-dialog>

  <view wx:if="{{scoreDialogVisible}}" class="score-mask" bindtap="closeScoreDialog">
    <view class="score-modal" catchtap="noop">
      <text class="score-title">给 {{scoreTargetName}} 记分</text>
      <text class="score-desc">请输入分数（数字键盘）</text>
      <input
        class="score-input"
        type="number"
        maxlength="6"
        value="{{scoreValue}}"
        focus="{{scoreDialogVisible}}"
        placeholder="请输入分值"
        bindinput="onScoreInput"
      />
      <view class="modal-actions">
        <button class="modal-btn ghost" bindtap="closeScoreDialog">取消</button>
        <button class="modal-btn" bindtap="confirmScore">确认</button>
      </view>
    </view>
  </view>

  <!-- 旁观者设置弹窗 -->
  <view wx:if="{{spectatorDialogVisible}}" class="score-mask" bindtap="closeSpectatorDialog">
    <view class="spectator-modal" catchtap="noop">
      <text class="spectator-title">旁观者设置</text>
      <text class="spectator-desc">旁观者不参与计分，仅可查看牌桌数据，点击头像可设置或取消旁观</text>
      <view class="spectator-list">
        <view
          wx:for="{{spectatorCandidates}}"
          wx:key="id"
          class="spectator-item {{item.selected ? 'selected' : ''}} {{item.disabled ? 'disabled' : ''}}"
          bindtap="toggleSpectatorCandidate"
          data-member-id="{{item.id}}"
        >
          <view class="spectator-avatar-wrap">
            <view wx:if="{{item.actorType === 'VIRTUAL' && item.nickname === '台板'}}" class="spectator-avatar table-icon">
              <text class="table-icon-text">台</text>
            </view>
            <image wx:elif="{{item.avatar}}" class="spectator-avatar" src="{{item.avatar}}" mode="aspectFill" />
            <view wx:else class="spectator-avatar spectator-avatar-text"><text>{{item.avatarInitials}}</text></view>
            <text wx:if="{{item.selected || item.disabled}}" class="spectator-badge">{{item.disabled ? (item.isOwner ? '桌主' : '固定') : '旁观'}}</text>
          </view>
          <text class="spectator-name">{{item.nickname}}</text>
        </view>
      </view>
      <view class="manage-footer spectator-footer">
        <button class="manage-footer-btn ghost" bindtap="closeSpectatorDialog">取消</button>
        <button class="manage-footer-btn" bindtap="confirmSpectators">确定</button>
      </view>
    </view>
  </view>
</view>
