<page-meta page-style="{{pageFontStyle}}" />
<view class="invite-page">
  <view class="bg-confetti"></view>

  <common-top-bar title="{{topBarTitle}}" bind:back="goBack" />

  <scroll-view class="content" scroll-y>
    <view class="action-strip-wrap">
      <view class="action-strip-shadow"></view>
      <view class="action-strip">
        <view class="action-item" bindtap="onActionTap" data-action="invite">
          <view class="action-icon"><view class="icon icon-invite"></view></view>
          <text>邀请</text>
        </view>
        <!-- <view class="action-item" bindtap="onActionTap" data-action="detail">
          <view class="action-icon"><view class="icon icon-detail"></view></view>
          <text>明细</text>
        </view> -->
        <view class="action-item" bindtap="onActionTap" data-action="settings">
          <view class="action-icon"><view class="icon icon-settings"></view></view>
          <text>设置</text>
        </view>
        <view class="action-item" bindtap="onActionTap" data-action="board">
          <view class="action-icon"><view class="icon icon-board"></view></view>
          <text>台板</text>
        </view>
        <view class="action-item {{!isOwner ? 'disabled' : ''}}" bindtap="onActionTap" data-action="end">
          <view class="action-icon"><view class="icon icon-power"></view></view>
          <text>结束</text>
        </view>
        <view class="action-item" bindtap="onActionTap" data-action="mute">
          <view class="action-icon"><view class="icon icon-mute"></view></view>
          <text>静音</text>
        </view>
        <view class="action-item" bindtap="onActionTap" data-action="more">
          <view class="action-icon"><view class="icon icon-more"></view></view>
          <text>更多</text>
        </view>
      </view>
    </view>

    <invite-card
      wx:if="{{showInlineInviteCard}}"
      roomCode="{{roomCode}}"
      codeDigits="{{codeDigits}}"
      codeFocus="{{codeFocus}}"
      roomStatus="{{roomStatus}}"
      showClose="{{true}}"
      editable="{{false}}"
      showJoinButton="{{false}}"
      showCopyButton="{{true}}"
      showShareButton="{{true}}"
      tipText="房间号仅用于分享邀请，加入操作请在首页完成"
      bind:share="handleShareInvite"
      bind:close="handleInlineInviteCardClose"
    />

    <view class="player-section {{showInlineInviteCard ? '' : 'tight-top'}}">
      <view class="player-head"><text>玩家数量: {{members.length}}</text></view>

      <view
        wx:for="{{members}}"
        wx:key="id"
        class="player-card {{item.id === currentMemberId ? 'self' : ''}}"
      >
        <view class="avatar-wrap">
          <image wx:if="{{item.avatar}}" class="avatar" src="{{item.avatar}}" mode="aspectFill" />
          <view wx:else class="avatar avatar-text"><text>{{item.avatarInitials || '游客'}}</text></view>
          <text wx:if="{{item.isOwner}}" class="host-tag">桌主</text>
        </view>

        <view class="player-info">
          <view class="name-row">
            <text class="player-name">{{item.nickname}}</text>
            <text wx:if="{{item.id === currentMemberId}}" class="self-tag">我</text>
          </view>
          <text class="player-desc">{{item.isOwner ? '房间管理员' : '普通玩家'}}</text>
        </view>

        <view class="score-wrap">
          <text class="score {{item.score >= 0 ? 'pos' : 'neg'}}">{{item.score}}</text>
          <text class="score-label">积分</text>
        </view>

        <view class="member-actions" wx:if="{{item.id !== currentMemberId}}">
          <view
            class="tiny-btn give-btn"
            bindtap="openScoreDialog"
            data-member-id="{{item.id}}"
            data-member-name="{{item.nickname}}"
            disabled="{{roomStatus !== 'IN_PROGRESS'}}"
          >给分</view>
          <view
            wx:if="{{isOwner && !item.isOwner && roomStatus === 'IN_PROGRESS'}}"
            class="tiny-btn owner-btn"
            bindtap="handleTransferOwner"
            data-member-id="{{item.id}}"
            data-member-name="{{item.nickname}}"
          >设桌主</view>
        </view>
      </view>

      <view wx:if="{{members.length === 0}}" class="empty-seat">
        <view class="icon icon-person-outline"></view>
        <text>虚位以待</text>
      </view>
    </view>

    <view class="records-card">
      <view class="records-head">
        <text>记分明细</text>
      </view>
      <view wx:if="{{scoreRecords.length === 0}}" class="empty-records">暂无记分记录</view>
      <view wx:for="{{scoreRecords}}" wx:key="id" class="record-item">
        <view class="record-main">
          <text class="name">{{item.fromMemberName}}</text>
          <text class="action">给了</text>
          <text class="name">{{item.toMemberName}}</text>
          <text class="points">{{item.points}}</text>
          <text class="action">分</text>
        </view>
        <text class="time">{{item.displayTime}}</text>
      </view>
    </view>
  </scroll-view>

  <common-dialog
    visible="{{invitePopupVisible}}"
    title="邀请好友加入"
    showClose="{{true}}"
    maskClosable="{{true}}"
    bind:close="closeInvitePopup"
  >
    <invite-card
      roomCode="{{roomCode}}"
      codeDigits="{{codeDigits}}"
      codeFocus="{{codeFocus}}"
      roomStatus="{{roomStatus}}"
      showClose="{{false}}"
      editable="{{false}}"
      showJoinButton="{{false}}"
      showCopyButton="{{true}}"
      tipText="复制房间号，发送给好友在首页加入"
      bind:share="handleShareInvite"
    />
    <view slot="footer" class="invite-popup-footer">
      <button class="invite-popup-btn ghost" bindtap="handleShareInvite">复制房间号</button>
      <button class="invite-popup-btn" open-type="share">微信分享</button>
    </view>
  </common-dialog>

  <view wx:if="{{scoreDialogVisible}}" class="score-mask" bindtap="closeScoreDialog">
    <view class="score-modal" catchtap="noop">
      <text class="score-title">给 {{scoreTargetName}} 记分</text>
      <text class="score-desc">请输入分数（数字键盘）</text>
      <input
        class="score-input"
        type="number"
        maxlength="6"
        value="{{scoreValue}}"
        focus="{{scoreDialogVisible}}"
        placeholder="请输入分值"
        bindinput="onScoreInput"
      />
      <view class="modal-actions">
        <button class="modal-btn ghost" bindtap="closeScoreDialog">取消</button>
        <button class="modal-btn" bindtap="confirmScore">确认</button>
      </view>
    </view>
  </view>
</view>
