<page-meta page-style="{{pageFontStyle}}" />
<view class="single-score-page">
  <view class="bg-confetti"></view>

  <common-top-bar title="{{topBarTitle}}" bind:back="goBack" />

  <scroll-view class="content" scroll-y>
    <view class="action-strip-wrap">
      <view class="action-strip-shadow"></view>
      <view class="action-strip">
        <view class="action-strip-head">
          <text class="action-strip-title">房间操作</text>
          <view class="room-status-chip {{roomStatus === 'IN_PROGRESS' ? 'active' : 'ended'}}">
            <text>{{roomStatus === 'IN_PROGRESS' ? '进行中' : '已结束'}}</text>
          </view>
        </view>
        <view class="action-strip-grid single-action-grid">
          <view
            class="action-item {{!isOwner || roomStatus !== 'IN_PROGRESS' || members.length >= 10 ? 'disabled' : ''}}"
            bindtap="handleActionTap"
            data-action="add"
          >
            <view class="action-icon"><view class="icon icon-plus"></view></view>
            <text>添加玩家</text>
          </view>
          <view class="action-item" bindtap="handleActionTap" data-action="detail">
            <view class="action-icon"><view class="icon icon-detail"></view></view>
            <text>记分明细</text>
          </view>
          <view
            class="action-item {{!isOwner || roomStatus !== 'IN_PROGRESS' ? 'disabled' : ''}}"
            bindtap="handleActionTap"
            data-action="end"
          >
            <view class="action-icon"><view class="icon icon-power"></view></view>
            <text>结束</text>
          </view>
        </view>
      </view>
    </view>

    <view class="player-section">
      <view class="player-head"><text>玩家 ({{members.length}})</text></view>

      <view
        wx:for="{{members}}"
        wx:key="id"
        class="player-card {{item.id === currentMemberId ? 'self' : ''}} {{item.isSpectator ? 'spectator' : ''}}"
      >
        <view class="avatar-wrap">
          <image wx:if="{{item.avatar}}" class="avatar" src="{{item.avatar}}" mode="aspectFill" />
          <view wx:else class="avatar avatar-text"><text>{{item.avatarInitials || '?'}}</text></view>
          <text wx:if="{{item.isOwner}}" class="host-tag">房主</text>
          <text wx:if="{{item.isSpectator}}" class="spectator-tag">旁观</text>
        </view>

        <view class="player-info">
          <view class="name-row">
            <text class="player-name">{{item.nickname}}</text>
            <text wx:if="{{item.id === currentMemberId}}" class="self-tag">我</text>
          </view>
          <view class="score-wrap-inline">
            <text class="score {{item.score >= 0 ? 'pos' : 'neg'}}">{{item.score}}</text>
            <text class="score-label">分</text>
          </view>
        </view>

        <view class="player-actions" wx:if="{{roomStatus === 'IN_PROGRESS' && members.length >= 2 && !currentMemberIsSpectator && !item.isSpectator}}">
          <view
            class="tiny-btn lose-btn"
            bindtap="openScoreDialog"
            data-type="lose"
            data-member-id="{{item.id}}"
            data-member-name="{{item.nickname}}"
          >输</view>
          <view
            class="tiny-btn win-btn"
            bindtap="openScoreDialog"
            data-type="win"
            data-member-id="{{item.id}}"
            data-member-name="{{item.nickname}}"
          >赢</view>
          <view
            wx:if="{{isOwner && !item.isOwner}}"
            class="tiny-btn kick-btn"
            bindtap="handleKickMember"
            data-member-id="{{item.id}}"
            data-member-name="{{item.nickname}}"
          >踢人</view>
        </view>
      </view>

      <view wx:if="{{members.length === 0}}" class="empty-hint">
        <text>暂无玩家，请添加玩家开始记分</text>
      </view>
      <view wx:elif="{{members.length === 1}}" class="empty-hint">
        <text>至少需要2名玩家才能记分，请继续添加</text>
      </view>
    </view>

    <score-record-list
      records="{{scoreRecords}}"
      normalActionText="输给"
    />
  </scroll-view>

  <!-- 添加玩家弹窗 -->
  <view wx:if="{{showAddModal}}" class="modal-mask" bindtap="closeAddModal">
    <view class="modal-box" catchtap="noop">
      <text class="modal-title">添加玩家</text>
      <input
        class="modal-input"
        placeholder="请输入玩家名字"
        value="{{newPlayerName}}"
        bindinput="onNameInput"
        focus="{{showAddModal}}"
        maxlength="20"
      />
      <view class="modal-actions">
        <view class="modal-btn ghost" bindtap="closeAddModal">取消</view>
        <view class="modal-btn" bindtap="confirmAddPlayer">确定</view>
      </view>
    </view>
  </view>

  <!-- 记分弹窗（选人 + 输入分数） -->
  <view wx:if="{{scoreDialogVisible}}" class="modal-mask" bindtap="closeScoreDialog">
    <view class="score-dialog" catchtap="noop">
      <text class="score-dialog-title">
        {{scoreDialogSourceName}} {{scoreDialogType === 'lose' ? '输给谁？' : '赢了谁？'}}
      </text>
      <text class="score-dialog-tip">可多选对手，确认后会按相同分数逐个记分</text>

      <view class="target-picker">
        <view
          wx:for="{{otherMembers}}"
          wx:key="id"
          class="target-item {{item.isSelected ? 'selected' : ''}}"
          bindtap="selectTarget"
          data-member-id="{{item.id}}"
        >
          <view class="target-avatar">
            <image wx:if="{{item.avatar}}" class="target-avatar-img" src="{{item.avatar}}" mode="aspectFill" />
            <view wx:else class="target-avatar-text">{{item.avatarInitials || '?'}}</view>
          </view>
          <view class="target-info">
            <text class="target-name">{{item.nickname}}</text>
            <text class="target-score {{item.score > 0 ? 'positive' : item.score < 0 ? 'negative' : ''}}">{{item.score > 0 ? '+' : ''}}{{item.score}}</text>
          </view>
          <view wx:if="{{item.isSelected}}" class="target-check">
            <view class="icon icon-check"></view>
          </view>
        </view>
      </view>

      <view class="batch-score-row">
        <text class="batch-score-label">批量{{scoreDialogType === 'lose' ? '扣' : '加'}}分</text>
        <switch
          checked="{{batchScoreEnabled}}"
          color="#e63946"
          bindchange="onBatchScoreToggle"
        />
      </view>

      <view class="score-input-section">
        <block wx:if="{{batchScoreEnabled}}">
          <text class="score-input-label">
            {{scoreDialogType === 'lose' ? '每人扣多少分？' : '每人加多少分？'}}
          </text>
          <input
            class="score-input"
            type="number"
            maxlength="6"
            value="{{scoreDialogValue}}"
            placeholder="请输入统一分数"
            focus="{{scoreDialogVisible && scoreDialogTargetIds.length > 0}}"
            bindinput="onScoreInput"
          />
        </block>
        <block wx:else>
          <text class="score-input-label">给每位已选玩家单独设置分数</text>
          <view class="target-score-editor">
            <view
              wx:for="{{otherMembers}}"
              wx:key="id"
              wx:if="{{item.isSelected}}"
              class="target-score-row"
            >
              <text class="target-score-name">{{item.nickname}}</text>
              <input
                class="target-score-input"
                type="number"
                maxlength="6"
                value="{{item.scoreValue}}"
                placeholder="分数"
                data-member-id="{{item.id}}"
                bindinput="onTargetScoreInput"
              />
            </view>
          </view>
        </block>
      </view>

      <view class="modal-actions">
        <view class="modal-btn ghost" bindtap="closeScoreDialog">取消</view>
        <view class="modal-btn {{scoreDialogType === 'lose' ? 'lose-confirm' : 'win-confirm'}}" bindtap="confirmScore">
          确认{{scoreDialogType === 'lose' ? '输' : '赢'}}
        </view>
      </view>
    </view>
  </view>
</view>
