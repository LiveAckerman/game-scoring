<page-meta page-style="{{pageFontStyle}}" />
<view class="page">
  <view class="bg-confetti"></view>
  <view class="blur-circle blur-circle-tl"></view>
  <view class="blur-circle blur-circle-br"></view>

  <view class="deco deco-trophy"><view class="deco-svg deco-svg-trophy"></view></view>
  <view class="deco deco-dollar"><view class="deco-svg deco-svg-dollar"></view></view>
  <view class="deco deco-casino"><view class="deco-svg deco-svg-casino"></view></view>

  <view class="main">
    <view class="icons-wrap">
      <view class="icons-glow"></view>
      <view class="icons-stack">
        <view class="icon-card icon-card-game">
          <view class="icon-svg icon-game"></view>
        </view>
        <view class="icon-card icon-card-smile">
          <view class="icon-svg icon-smile"></view>
        </view>
        <view class="icon-card icon-card-star">
          <view class="icon-svg icon-star"></view>
        </view>
      </view>
    </view>

    <view class="brand">
      <text class="title">欢乐记分馆</text>
      <text class="subtitle">好友聚会 · 轻松记分 · 快乐加倍</text>
    </view>

    <view class="btn-wrap">
      <button class="btn-wechat" bindtap="handleLogin">
        <view class="btn-wechat-inner">
          <view class="wechat-icon"></view>
          <text>微信一键登录</text>
        </view>
      </button>
    </view>
  </view>

  <view class="footer">
    <view class="agreement-row">
      <checkbox-group bindchange="handleAgreementChange">
        <label class="agreement-label">
          <checkbox value="agreement" checked="{{isAgreed}}" color="#E63946" />
          <text class="agreement-text">我已阅读并同意</text>
          <text class="link">《用户协议》</text>
          <text class="agreement-text">和</text>
          <text class="link">《隐私政策》</text>
        </label>
      </checkbox-group>
    </view>
    <text class="footer-tip">首次登录会先完善头像和昵称，方便牌桌里快速认人</text>
  </view>
</view>
