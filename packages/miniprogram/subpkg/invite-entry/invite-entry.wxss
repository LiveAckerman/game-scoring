.invite-entry-page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--c-surface-app), #fff0e4);
  display: flex;
  flex-direction: column;
}

.invite-entry-body {
  flex: 1;
  padding: 24rpx 24rpx 28rpx;
  box-sizing: border-box;
}

.hero-card {
  display: flex;
  gap: 22rpx;
  align-items: center;
  padding: 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #af291e 0%, var(--c-brand-red) 54%, #eb9320 100%);
  box-shadow: 0 16rpx 34rpx rgba(183, 55, 39, 0.2);
  color: #fff8f2;
}

.hero-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  background: rgba(255, 248, 242, 0.18);
  border: 2rpx solid rgba(255, 224, 180, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-xl, 38rpx);
  font-weight: 700;
  flex-shrink: 0;
}

.hero-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-kicker {
  font-size: var(--fs-sm, 24rpx);
  color: #ffe4bf;
}

.hero-title {
  font-size: var(--fs-xl, 38rpx);
  line-height: 1.25;
  font-weight: 700;
}

.hero-desc {
  font-size: var(--fs-sm, 24rpx);
  line-height: 1.55;
  color: rgba(255, 248, 242, 0.92);
}

.preview-card,
.notice-card {
  margin-top: 18rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, var(--c-surface-card), var(--c-surface-card-alt));
  border: 2rpx solid var(--c-border-soft);
  box-shadow: 0 12rpx 24rpx rgba(183, 55, 39, 0.08);
}

.preview-card.empty {
  text-align: center;
  padding: 38rpx 26rpx;
}

.preview-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.room-name {
  display: block;
  font-size: var(--fs-lg, 34rpx);
  color: var(--c-text-primary);
  font-weight: 700;
  line-height: 1.3;
}

.room-code {
  display: block;
  margin-top: 8rpx;
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-text-secondary);
}

.badge-group {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex-shrink: 0;
}

.badge {
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: var(--fs-xs, 20rpx);
  font-weight: 700;
}

.badge.type.type-multi {
  background: var(--c-brand-red-soft);
  color: var(--c-brand-red-strong);
}

.badge.type.type-single {
  background: var(--c-brand-gold-soft);
  color: var(--c-brand-gold-strong);
}

.badge.type.type-pool {
  background: #f4eadc;
  color: #7a5947;
}

.badge.status.active {
  background: var(--c-success-bg);
  color: var(--c-success-fg);
}

.badge.status.ended {
  background: var(--c-danger-bg);
  color: var(--c-danger-fg);
}

.member-section {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed rgba(199, 58, 45, 0.12);
}

.section-title,
.notice-title {
  display: block;
  font-size: var(--fs-base, 28rpx);
  color: var(--c-text-primary);
  font-weight: 700;
}

.member-row {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
}

.member-avatar,
.member-more {
  width: 70rpx;
  height: 70rpx;
  margin-right: -10rpx;
  border-radius: 35rpx;
  border: 4rpx solid var(--c-surface-card);
  background: linear-gradient(135deg, var(--c-brand-gold), var(--c-brand-red));
  color: #fff8f2;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-sm, 24rpx);
  font-weight: 700;
  overflow: hidden;
  box-sizing: border-box;
}

.member-avatar.owner {
  box-shadow: 0 0 0 2rpx rgba(224, 161, 40, 0.3);
}

.member-image {
  width: 100%;
  height: 100%;
}

.member-more {
  background: var(--c-surface-warm);
  color: var(--c-text-secondary);
}

.member-tip,
.notice-item,
.empty-desc {
  display: block;
  margin-top: 14rpx;
  font-size: var(--fs-sm, 24rpx);
  line-height: 1.65;
  color: var(--c-text-secondary);
}

.empty-title {
  display: block;
  font-size: var(--fs-lg, 34rpx);
  color: var(--c-text-primary);
  font-weight: 700;
}

.action-bar {
  display: flex;
  gap: 14rpx;
  padding: 0 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 22rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-base, 28rpx);
  font-weight: 700;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--c-brand-red), #e25b33);
  color: var(--c-text-on-brand);
  box-shadow: 0 14rpx 28rpx rgba(183, 55, 39, 0.14);
}

.action-btn.primary[disabled] {
  background: #e6d8d1;
  color: #9d877d;
  box-shadow: none;
}

.action-btn.ghost {
  background: var(--c-surface-warm);
  color: var(--c-text-secondary);
}

.action-btn::after {
  border: none;
}
