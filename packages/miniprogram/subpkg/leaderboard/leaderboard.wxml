<page-meta page-style="{{pageFontStyle}}" />
<view class="leaderboard-page">
  <common-top-bar title="战绩排行榜" bind:back="onBack" />

  <view class="tab-bar">
    <view
      class="tab-item {{activeTab === 0 ? 'active' : ''}}"
      data-tab="0"
      bindtap="switchTab"
    >综合</view>
    <view
      class="tab-item {{activeTab === 1 ? 'active' : ''}}"
      data-tab="1"
      bindtap="switchTab"
    >胜率</view>
    <view
      class="tab-item {{activeTab === 2 ? 'active' : ''}}"
      data-tab="2"
      bindtap="switchTab"
    >场次</view>
  </view>

  <scroll-view class="content" scroll-y>
    <view wx:if="{{loading}}" class="loading-wrap">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view wx:elif="{{rankList.length === 0}}" class="empty-state">
      <view class="icon icon-trophy"></view>
      <text class="empty-title">暂无战绩数据</text>
      <text class="empty-desc">与好友一起游戏后，排行榜将显示在这里</text>
    </view>

    <view wx:else class="rank-list">
      <view
        wx:for="{{rankList}}"
        wx:key="id"
        class="rank-card rank-{{index < 3 ? index + 1 : 'other'}}"
      >
        <view class="rank-badge rank-badge-{{index < 3 ? index + 1 : 'other'}}">
          <text wx:if="{{index < 3}}" class="rank-medal">{{index + 1}}</text>
          <text wx:else class="rank-num">{{index + 1}}</text>
        </view>
        <view class="avatar-wrap">
          <image wx:if="{{item.avatar}}" class="avatar" src="{{item.avatar}}" mode="aspectFill" />
          <view wx:else class="avatar avatar-text"><text>{{item.nickname ? item.nickname[0] : '?'}}</text></view>
        </view>
        <view class="player-info">
          <text class="player-name">{{item.nickname || '游客'}}</text>
          <text wx:if="{{item.actorType === 'GUEST'}}" class="guest-tag">游客</text>
          <view class="stats-row">
            <text class="stat">胜率 {{item.winRate}}</text>
            <text class="stat-dot">&#183;</text>
            <text class="stat">共 {{item.totalGames}} 场</text>
            <text class="stat-dot">&#183;</text>
            <text class="stat stat-wins">胜 {{item.wins}}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
