.pool-record-page {
  min-height: 100vh;
  background: var(--c-surface-app);
  display: flex;
  flex-direction: column;
}

/* ───────── 圈次信息 ───────── */
.round-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx 12rpx;
}
.round-info-left {
  display: flex;
  align-items: baseline;
  flex: 1;
  min-width: 0;
}
.round-title {
  font-size: var(--fs-base, 28rpx);
  color: var(--c-text-primary);
  font-weight: 600;
}
.round-balance {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--c-brand-red);
  margin-left: 8rpx;
}
.round-unit {
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-brand-red);
  margin-left: 4rpx;
}
.round-info-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.round-action-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 28rpx;
  border-radius: 16rpx;
  font-size: var(--fs-sm, 24rpx);
  font-weight: 700;
  background: var(--c-surface-card);
  white-space: nowrap;
}
.round-action-btn.table-take {
  border: 2rpx solid var(--c-success-fg);
  color: var(--c-success-fg);
}
.round-action-btn.end-round {
  border: 2rpx solid var(--c-brand-red);
  color: var(--c-brand-red);
}

/* ───────── 圈结束提示 ───────── */
.round-ended-tip {
  text-align: center;
  padding: 24rpx;
  color: var(--c-text-muted);
  font-size: var(--fs-base, 28rpx);
}
.back-btn {
  display: inline-block;
  margin-top: 16rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 48rpx;
  background: var(--c-success-fg);
  color: var(--c-text-on-brand);
  border-radius: 36rpx;
  font-size: var(--fs-base, 28rpx);
  font-weight: 700;
}

/* ───────── 记录列表 ───────── */
.records-list {
  flex: 1;
  padding: 0 24rpx;
}
.record-card {
  background: var(--c-surface-card);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--c-border-soft);
}
.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}
.record-seq {
  font-size: var(--fs-base, 28rpx);
  font-weight: 700;
  color: var(--c-text-primary);
}
.record-time {
  font-size: var(--fs-xs, 20rpx);
  color: var(--c-text-muted);
}
.record-body {
  display: flex;
  align-items: center;
}
.record-actor {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}
.record-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  border: 2rpx solid var(--c-border-soft);
  flex-shrink: 0;
}
.record-avatar-text {
  background: linear-gradient(135deg, var(--c-brand-gold), var(--c-brand-red));
  color: var(--c-text-on-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-sm, 24rpx);
  font-weight: 700;
}
.table-icon-sm {
  border-radius: 12rpx !important;
  background: var(--c-success-fg) !important;
  border-color: var(--c-success-fg) !important;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--c-text-on-brand);
  font-size: var(--fs-base, 28rpx);
  font-weight: 700;
}
.record-nickname {
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-text-secondary);
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.record-type {
  font-size: var(--fs-base, 28rpx);
  font-weight: 700;
  color: var(--c-text-primary);
  margin: 0 16rpx;
}
.record-type.take {
  color: var(--c-brand-red);
}
.record-type.give {
  color: var(--c-text-primary);
}
.record-points-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.record-points {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--c-text-primary);
}
.record-points-unit {
  font-size: var(--fs-sm, 24rpx);
  color: var(--c-text-secondary);
}
.empty-records {
  text-align: center;
  padding: 60rpx 0;
  color: var(--c-text-muted);
  font-size: var(--fs-base, 28rpx);
}
.records-end {
  text-align: center;
  padding: 24rpx 0;
  color: var(--c-text-muted);
  font-size: var(--fs-xs, 20rpx);
}

/* ───────── 底部操作按钮 ───────── */
.bottom-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--c-surface-card);
  border-top: 1rpx solid var(--c-border-soft);
}
.bottom-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  text-align: center;
  font-size: var(--fs-base, 28rpx);
  font-weight: 600;
}
.bottom-btn .bold {
  font-weight: 700;
}
.take-btn {
  border: 2rpx solid var(--c-brand-red);
  color: var(--c-brand-red);
  background: var(--c-surface-card);
}
.give-btn {
  background: var(--c-success-fg);
  color: var(--c-text-on-brand);
}

/* ───────── 弹窗 ───────── */
.dialog-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.38);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
}
.dialog-modal {
  width: 100%;
  background: var(--c-surface-card);
  border-radius: 26rpx;
  padding: 28rpx;
  box-sizing: border-box;
}
.dialog-title {
  display: block;
  font-size: var(--fs-lg, 34rpx);
  font-weight: 700;
  color: var(--c-text-primary);
}
.dialog-desc {
  display: block;
  margin-top: 8rpx;
  margin-bottom: 18rpx;
  color: var(--c-text-secondary);
  font-size: var(--fs-sm, 24rpx);
}
.dialog-input {
  height: 98rpx;
  border-radius: 18rpx;
  border: 2rpx solid var(--c-border-strong);
  background: var(--c-surface-warm);
  text-align: center;
  font-size: 52rpx;
  font-weight: 700;
  color: var(--c-success-fg);
  margin-bottom: 18rpx;
}
.dialog-actions {
  display: flex;
  gap: 12rpx;
}
.dialog-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 18rpx;
  margin: 0;
  background: var(--c-success-fg);
  color: var(--c-text-on-brand);
  font-size: var(--fs-base, 28rpx);
  font-weight: 700;
}
.dialog-btn.ghost {
  background: var(--c-surface-warm);
  color: var(--c-text-secondary);
}
.dialog-btn::after {
  border: none;
}
