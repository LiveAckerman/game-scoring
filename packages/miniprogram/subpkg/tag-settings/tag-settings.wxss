.tag-page {
  min-height: 100vh;
  background: var(--c-surface-app);
  display: flex;
  flex-direction: column;
}

.tag-scroll {
  flex: 1;
  padding: 20rpx 24rpx 36rpx;
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(135deg, var(--c-brand-red), var(--c-brand-gold));
  border-radius: 30rpx;
  padding: 30rpx;
  color: var(--c-text-on-brand);
  box-shadow: 0 16rpx 30rpx rgba(183, 55, 39, 0.14);
  margin-bottom: 18rpx;
}

.hero-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.hero-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.92;
}

.tag-card {
  background: var(--c-surface-card);
  border-radius: 28rpx;
  padding: 28rpx;
  border: 2rpx solid var(--c-border-soft);
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text-primary);
}

.section-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--c-text-muted);
}

.create-btn {
  min-width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 20rpx;
  border-radius: 30rpx;
  background: var(--c-surface-gold);
  color: var(--c-brand-gold-strong);
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
  box-sizing: border-box;
}

.empty-box {
  padding: 46rpx 24rpx;
  border-radius: 24rpx;
  background: var(--c-surface-card-alt);
  border: 2rpx dashed var(--c-border-soft);
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--c-text-primary);
  margin-bottom: 10rpx;
}

.empty-desc {
  display: block;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--c-text-muted);
}

.tag-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tag-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: var(--c-surface-card-alt);
}

.tag-chip {
  min-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 32rpx;
  border: 2rpx solid var(--c-brand-red);
  display: inline-flex;
  align-items: center;
  box-sizing: border-box;
  font-size: 26rpx;
  font-weight: 700;
}

.tag-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.mini-btn {
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  background: var(--c-surface-card-alt);
  color: var(--c-text-secondary);
  font-size: 22rpx;
  font-weight: 700;
}

.mini-btn.danger {
  background: var(--c-danger-bg);
  color: var(--c-danger-fg);
}

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.38);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.sheet-panel {
  width: 100%;
  background: var(--c-surface-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.sheet-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text-primary);
}

.sheet-close {
  font-size: 24rpx;
  color: var(--c-text-muted);
}

.field-block {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: var(--c-text-muted);
}

.name-input {
  height: 88rpx;
  border-radius: 20rpx;
  background: var(--c-surface-card);
  border: 2rpx solid var(--c-border-soft);
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--c-text-primary);
}

.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.color-item {
  width: 68rpx;
  height: 68rpx;
  border-radius: 34rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 0 0 2rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.color-item.selected {
  box-shadow: 0 0 0 4rpx rgba(230, 57, 70, 0.16);
}

.sheet-actions {
  display: flex;
  gap: 14rpx;
}

.sheet-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 22rpx;
  background: var(--c-brand-red);
  color: var(--c-text-on-brand);
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
}

.sheet-btn.ghost {
  background: var(--c-surface-warm);
  color: var(--c-text-secondary);
}
